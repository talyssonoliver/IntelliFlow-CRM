#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# IntelliFlow CRM Pre-commit Hook
# Fast checks only (~30s): format, lint, typecheck, auto-sync inventories.
# Full test suite runs in CI — do not add slow steps here.

echo "🔍 Running pre-commit checks..."

# Auto-regenerate Sprint Plan split files if source CSV changed
if git diff --cached --name-only | grep -q "Sprint_plan\.csv$"; then
  echo "📊 Sprint_plan.csv changed - regenerating local split files..."
  npx tsx tools/scripts/split-sprint-plan.ts || {
    echo "❌ Failed to split Sprint_plan.csv"
    exit 1
  }
  echo "✅ Local split files regenerated"
fi

# Always sync both inventories — CI detects drift unconditionally so must we.
# These are idempotent and fast (~5s). Pattern-gating caused false negatives
# (any file change outside the patterns left baseline.json stale → CI fail).
echo "📦 Syncing inventories..."
npx tsx tools/scripts/sync-api-inventory.ts || {
  echo "❌ Failed to sync API inventory"
  exit 1
}
npx tsx tools/scripts/sync-codebase-inventory.ts || {
  echo "❌ Failed to sync codebase inventory"
  exit 1
}
git add artifacts/benchmarks/baseline.json
echo "✅ Inventories synced and staged"

# PG-195 / ADR-046: auto-regenerate Material Symbols subset + audit when any
# scanned source file changes. Mirrors the auto-regenerate precedent above —
# dev edits an icon, commit just works; font + audit JSON get staged
# automatically. If nothing drifted, --verify exits 0 and we do nothing.
ICON_SCAN_PATTERNS="^apps/web/src/|^packages/ui/src/"
if git diff --cached --name-only | grep -qE "$ICON_SCAN_PATTERNS"; then
  if ! node tools/scripts/subset-material-symbols.mjs --verify >/dev/null 2>&1; then
    echo "🔤 Material Symbols drift detected - regenerating font + audit..."
    node tools/scripts/subset-material-symbols.mjs || {
      echo "❌ Failed to regenerate Material Symbols subset. Fix the scanner error and retry."
      echo "   (See docs/design/ICON_USAGE.md for troubleshooting.)"
      exit 1
    }
    git add apps/web/public/fonts/MaterialSymbolsOutlined.woff2 artifacts/reports/material-symbols-glyph-audit.json
    echo "✅ Material Symbols font + audit regenerated and staged"
  fi
fi

# Secret scan (gitleaks) - fail fast locally before CI
echo "🔐 Scanning for secrets..."
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --redact --config=.gitleaks.toml --no-banner || {
    echo "❌ Secret scan failed. Remove secrets before committing."
    echo "   If this is a false positive, add to .gitleaks.toml allowlist."
    exit 1
  }
  echo "✅ No secrets detected"
else
  echo "⚠️  gitleaks not installed — skipping local secret scan (CI will still run it)."
fi

# Auto-format staged files then re-stage them
echo "💅 Auto-formatting staged files..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx|json|md)$' || true)
if [ -n "$STAGED_FILES" ]; then
  echo "$STAGED_FILES" | xargs npx prettier --write --log-level=warn
  echo "$STAGED_FILES" | xargs git add -f
  echo "✅ Formatting applied and re-staged"
fi

# Auto-fix lint on STAGED .ts/.tsx files only, then re-stage. Per audit
# §10-C: `pnpm run lint` (turbo run lint) fails the whole monorepo lint
# on any pre-existing violation in a package the developer isn't even
# touching. `pnpm run lint:fix` (turbo run lint:fix) fixes everything
# everywhere — drive-by edits to unrelated packages.
#
# This pattern: scope to staged files, run eslint --fix on JUST them,
# re-stage, then verify zero remaining problems. Eliminates the "lint
# failed in CI" class of waste while NOT touching files the developer
# didn't modify. Falls through to the original full lint if nothing was
# staged (covers commits that only touch non-TS files).
#
# Override: ESCAPE_LINT_FIX=1 git commit ... if the staged-files pass
# is misbehaving (then run the full lint manually).
echo "📋 Auto-fixing + linting staged .ts/.tsx files..."
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx|mjs|cjs)$' || true)
# `-r` is a GNU-xargs extension that breaks on macOS/BSD ("illegal option").
# We don't need it here because the `[ -n "$STAGED_TS" ]` guard below
# already ensures non-empty input; POSIX xargs without `-r` would also
# run eslint with zero args, which is what we're guarding against.
if [ -n "$STAGED_TS" ] && [ "${ESCAPE_LINT_FIX:-0}" != "1" ]; then
  # eslint --fix mutates files in place. Use --max-warnings=0 so any
  # remaining violation (one we can't auto-fix) still blocks the commit.
  # `2>/dev/null || true` on `git add` because some staged files may be
  # in directories ESLint ignored (e.g., dist/) — re-staging only matters
  # for files we actually fixed.
  echo "$STAGED_TS" | xargs pnpm exec eslint --fix --max-warnings=0 || {
    echo "❌ Lint failed on staged files after autofix. Fix the remaining errors before committing."
    echo "   (Override only if necessary: ESCAPE_LINT_FIX=1 git commit ... — record reason in commit body.)"
    exit 1
  }
  echo "$STAGED_TS" | xargs git add -f 2>/dev/null || true
  echo "✅ Staged files lint-fixed and re-staged"
else
  echo "⚠️  No staged TS/JS files (or ESCAPE_LINT_FIX=1). Falling back to monorepo lint."
  pnpm run lint "--filter=!@intelliflow/project-tracker" || {
    echo "❌ Linting failed. Fix errors before committing."
    exit 1
  }
fi

# Run type checking
echo "🔧 Type checking..."
pnpm run typecheck || {
  echo "❌ Type checking failed. Fix type errors before committing."
  exit 1
}

# Repo policy (2026-05-02): no new lint silencers in source code. Refactor
# properly instead. Catches `eslint-disable*` (line + block forms, JS and JSX
# comment styles) and `@ts-ignore` / `@ts-expect-error` / `@ts-nocheck` added
# in this commit's STAGED-line set. Pre-existing lines are not flagged.
#
# Override: ESCAPE_LINT_SILENCER=1 git commit ... (only with explicit user
# approval — record the reason in the commit body).
if [ "${ESCAPE_LINT_SILENCER:-0}" != "1" ]; then
  STAGED_TS=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx|mjs|cjs)$' || true)
  if [ -n "$STAGED_TS" ]; then
    SILENCER_HITS=""
    for f in $STAGED_TS; do
      # Only inspect lines being ADDED (start with + but not +++); skip removed lines.
      ADDED=$(git diff --cached -- "$f" | grep -E '^\+[^+]' | grep -E 'eslint-disable|@ts-ignore|@ts-expect-error|@ts-nocheck' || true)
      if [ -n "$ADDED" ]; then
        SILENCER_HITS="${SILENCER_HITS}
${f}:
${ADDED}
"
      fi
    done
    if [ -n "$SILENCER_HITS" ]; then
      echo ""
      echo "❌ New lint silencer(s) staged. Repo policy: refactor, never suppress."
      echo "$SILENCER_HITS"
      echo ""
      echo "Forbidden directives in NEW code:"
      echo "  • // eslint-disable / // eslint-disable-next-line / /* eslint-disable */"
      echo "  • {/* eslint-disable */}"
      echo "  • // @ts-ignore / // @ts-expect-error / // @ts-nocheck"
      echo ""
      echo "Fix the underlying issue (extract helper, use semantic HTML, narrow"
      echo "the type, drop the unused import). If you genuinely cannot, override"
      echo "with ESCAPE_LINT_SILENCER=1 git commit ... and document WHY in the"
      echo "commit body."
      exit 1
    fi
  fi
fi

# Repo policy (2026-05-03, hardened after GitHub secret-scanning alert #2
# pattern-matched a fake `.stub` JWT as a real Supabase service key — its
# detector only checks shape, not the signature suffix). No JWT-shaped
# stubs are allowed in source files at all, real or fake. Use non-JWT
# placeholders instead.
#
# Whitelist exemptions:
#   - "stub", "ci-build-stub-...", "ci-stub-..." literal placeholders (no `eyJ` prefix)
#   - "AAAA...A=" — base64 of 32 zero bytes (intentional CI build stub)
#   - Lines that reference "${{ secrets.X }}" — GH Actions secret ref, value lives server-side
#   - 64-hex inside SHA256 hash fields (artifacts/coverage outputs)
#
# What we catch:
#   - ANY `eyJ...` JWT (no `.stub` exception — GH's scanner doesn't honor it)
#   - `sk-`, `ghp_`, `xoxb-`, `xoxp-` prefixes (OpenAI / GitHub / Slack)
#   - `AKIA[A-Z0-9]{16}` (AWS access keys)
#   - 32+ char base64 OR 40+ char hex strings on a literal-assignment line
#     (key/secret/token/password/api on the same line)
#
# Override: ALLOW_SECRET_LIKE=1 (only with explicit user approval).
if [ "${ALLOW_SECRET_LIKE:-0}" != "1" ]; then
  STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -vE '\.(lock|map|woff2?|png|jpe?g|gif|ico|svg|pdf)$' || true)
  if [ -n "$STAGED_FILES" ]; then
    SECRET_HITS=""
    for f in $STAGED_FILES; do
      # Only NEW lines (+ prefix, not +++). `|| true` because grep returns 1
      # when there are no matches and `sh -e` would abort the hook on that.
      DIFF_ADDED=$(git diff --cached -- "$f" | grep -E '^\+[^+]' || true)
      [ -z "$DIFF_ADDED" ] && continue

      # 1) ANY eyJ... JWT shape — no .stub exception. GitHub's secret
      # scanner pattern-matches every JWT-shaped value as a real provider
      # key regardless of signature, so our own gate must too. The fake
      # signature (".stub") doesn't fool it. Use non-JWT placeholders.
      JWT_HIT=$(echo "$DIFF_ADDED" | grep -E 'eyJ[A-Za-z0-9_-]{10,}\.eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{4,}' | grep -vE '\$\{\{\s*secrets\.' || true)

      # 2) Provider-prefixed tokens (OpenAI / GitHub / Slack / AWS)
      PROVIDER_HIT=$(echo "$DIFF_ADDED" | grep -E '(sk-[A-Za-z0-9]{32,}|ghp_[A-Za-z0-9]{36,}|xox[bpas]-[A-Za-z0-9-]{20,}|AKIA[A-Z0-9]{16})' | grep -vE '\$\{\{\s*secrets\.' || true)

      # 3) Long opaque assignment (key/secret/token/password/api in the var name)
      OPAQUE_HIT=$(echo "$DIFF_ADDED" | grep -iE '(key|secret|token|password|api[_-]?key)\s*[:=]\s*["'\'']([A-Za-z0-9+/=_-]{32,}|[a-f0-9]{40,})["'\'']' | grep -vE '\$\{\{\s*secrets\.|stub|ci-build|ci-audit|AAAAAAA|placeholder|example|test[_-]?key|0{32,}' || true)

      if [ -n "$JWT_HIT$PROVIDER_HIT$OPAQUE_HIT" ]; then
        SECRET_HITS="${SECRET_HITS}
${f}:
${JWT_HIT}${PROVIDER_HIT}${OPAQUE_HIT}
"
      fi
    done
    if [ -n "$SECRET_HITS" ]; then
      echo ""
      echo "❌ Possible real secret(s) staged."
      echo "$SECRET_HITS"
      echo ""
      echo "Repo policy: real keys never enter git. Move the value to a"
      echo "GitHub Actions secret and reference it via \${{ secrets.X }}."
      echo "If this is a known stub/example, override with ALLOW_SECRET_LIKE=1"
      echo "and document why in the commit body."
      exit 1
    fi
  fi
fi

# Preship guards (CI failure categories A/C/D) — staged-only fast mode.
# Detects, at commit time, the three classes that recently reached main:
#   • vitest teardown-crash exits ("all tests passed" but process exited 1)
#   • ioredis/BullMQ clients instantiated with no `.on('error')` handler
#   • Prisma migrations granting to a role the CI bootstrap never creates
# Only NEW instantiations / changed migrations are inspected, so editing an
# unrelated part of a file with a pre-existing finding does not block you.
# Opt-out is per-finding (`// preship-allow-unhandled-error` + justification),
# never a blanket skip. Full audit: `pnpm preship:guards`.
# See docs/runbooks/preship-guards.md.
echo "🛡️  Running preship guards (staged-only)..."
node tools/scripts/preship/index.mjs --staged-only || {
  echo "❌ Preship guards failed. See docs/runbooks/preship-guards.md for details + opt-out."
  exit 1
}

echo "✅ All pre-commit checks passed! (Full tests run in CI)"
