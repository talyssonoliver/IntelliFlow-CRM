#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# IntelliFlow CRM Pre-commit Hook
# Ensure turbo is reachable from the monorepo root node_modules
PATH="C:/Users/talys/projects/intelliFlow-CRM/node_modules/.bin:$PATH"

# Fast checks only (~30s): format, lint, typecheck, auto-sync inventories.
# Full test suite runs in CI — do not add slow steps here.

echo "🔍 Running pre-commit checks..."
# Wave 4 one-time cleanup: un-track Sprint_plan_[A-Z].csv splits if any are
# still tracked in git (they are now gitignored derived files).
# This block is idempotent -- git rm --cached is a no-op when files are already
# untracked. Uses git ls-files --error-unmatch to test before removing.
for _split_letter in A B C D E F G H I J; do
  _split_file="apps/project-tracker/docs/metrics/_global/Sprint_plan_${_split_letter}.csv"
  if git ls-files --error-unmatch "$_split_file" >/dev/null 2>&1; then
    echo "Wave 4: un-tracking derived file ${_split_file}..."
    git rm --cached -f "$_split_file" >/dev/null 2>&1 || true
  fi
done



# Auto-regenerate Sprint Plan split files if source CSV changed
if git diff --cached --name-only | grep -q "Sprint_plan\.csv$"; then
  echo "📊 Sprint_plan.csv changed - regenerating local split files..."
  npx tsx tools/scripts/split-sprint-plan.ts || {
    echo "❌ Failed to split Sprint_plan.csv"
    exit 1
  }
  echo "✅ Local split files regenerated"
fi

# Auto-sync API inventory if router files changed
if git diff --cached --name-only | grep -q "\.router\.ts$"; then
  echo "🔄 Router files changed - syncing API inventory..."
  npx tsx tools/scripts/sync-api-inventory.ts || {
    echo "❌ Failed to sync API inventory"
    exit 1
  }
  git add artifacts/benchmarks/baseline.json
  echo "✅ API inventory synced and staged"
fi

# Auto-sync codebase inventory if relevant source files changed
CODEBASE_PATTERNS="schema\.prisma|middleware/|workers/|adapters/src/|domain/src/events|validators/src/"
if git diff --cached --name-only | grep -qE "$CODEBASE_PATTERNS"; then
  echo "🔄 Codebase files changed - syncing full inventory..."
  npx tsx tools/scripts/sync-codebase-inventory.ts || {
    echo "❌ Failed to sync codebase inventory"
    exit 1
  }
  git add artifacts/benchmarks/baseline.json
  echo "✅ Codebase inventory synced and staged"
fi

# PG-195 / ADR-046: auto-regenerate Material Symbols subset + audit when any
# scanned source file changes. Mirrors the auto-regenerate precedent above —
# dev edits an icon, commit just works; font + audit JSON get staged
# automatically. If nothing drifted, --verify exits 0 and we do nothing.
ICON_SCAN_PATTERNS="^apps/web/src/|^packages/ui/src/"
if git diff --cached --name-only | grep -qE "$ICON_SCAN_PATTERNS"; then
  if ! node tools/scripts/subset-material-symbols.mjs --verify >/dev/null 2>&1; then
    echo "🔤 Material Symbols drift detected - regenerating font + audit..."
    node tools/scripts/subset-material-symbols.mjs || {
      echo "❌ Failed to regenerate Material Symbols subset. Fix the scanner error and retry."
      echo "   (See docs/design/ICON_USAGE.md for troubleshooting.)"
      exit 1
    }
    git add apps/web/public/fonts/MaterialSymbolsOutlined.woff2 artifacts/perf/material-symbols-glyph-audit.json
    echo "✅ Material Symbols font + audit regenerated and staged"
  fi
fi

# Secret scan (gitleaks) - fail fast locally before CI
echo "🔐 Scanning for secrets..."
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --redact --config=.gitleaks.toml --no-banner || {
    echo "❌ Secret scan failed. Remove secrets before committing."
    echo "   If this is a false positive, add to .gitleaks.toml allowlist."
    exit 1
  }
  echo "✅ No secrets detected"
else
  echo "⚠️  gitleaks not installed — skipping local secret scan (CI will still run it)."
fi

# Auto-format staged files then re-stage them
echo "💅 Auto-formatting staged files..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx|json|md)$' || true)
if [ -n "$STAGED_FILES" ]; then
  echo "$STAGED_FILES" | xargs npx prettier --write --log-level=warn
  echo "$STAGED_FILES" | xargs git add -f
  echo "✅ Formatting applied and re-staged"
fi

# Run linting (excluding project-tracker which has known isolated TS issues)
echo "📋 Linting code..."
# Skip in worktrees without pnpm install (CI will enforce)
if [ -d "packages/domain/node_modules" ]; then
  pnpm run lint "--filter=!@intelliflow/project-tracker" || {
    echo "❌ Linting failed. Fix errors before committing."
    exit 1
  }
else
  echo "⚠️  Worktree without pnpm setup — skipping lint (CI will enforce)"
fi

# Run type checking
echo "🔧 Type checking..."
# Skip in worktrees without pnpm install (CI will enforce)
if [ -d "packages/domain/node_modules" ]; then
  pnpm run typecheck || {
    echo "❌ Type checking failed. Fix type errors before committing."
    exit 1
  }
else
  echo "⚠️  Worktree without pnpm setup — skipping typecheck (CI will enforce)"
fi

echo "✅ All pre-commit checks passed! (Full tests run in CI)"
