#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# IntelliFlow CRM Commit Message Validation
#
# Single source of truth: delegates to tools/audit/commit_msg_lint.py — the SAME
# linter CI's `system-audit` runs (mirrors tools/scripts/commitlint.config.js).
# This replaced a hand-rolled shell regex that drifted from CI: it enforced
# subject *length* but NOT subject *case*, so an upper-case subject like
# "feat(ai-worker): OpenRouter…" passed locally and only reddened in CI (#340).
# Routing the hook + pre-ship + CI through one linter makes that drift impossible.

echo "📝 Validating commit message..."
COMMIT_MSG_FILE=$1

# Prefer python3, then python (Windows ships `python`).
if command -v python3 >/dev/null 2>&1; then PY=python3
elif command -v python >/dev/null 2>&1; then PY=python
else PY=""; fi

if [ -n "$PY" ]; then
  if "$PY" tools/audit/commit_msg_lint.py --message-file "$COMMIT_MSG_FILE"; then
    echo "✅ Commit message validated!"
    exit 0
  fi
  echo ""
  echo "Conventional Commits — type(scope?): subject"
  echo "  • subject: lower-case start, 10–100 chars, no trailing period"
  echo "  • body/footer lines ≤ 100 chars"
  echo "  • no AI-coauthor trailers (repo policy)"
  echo ""
  echo "Same rules CI's system-audit enforces. Fix the message and re-commit."
  exit 1
fi

# --- Fallback: python unavailable. Basic conventional-commit format only.
# Full rules (subject-case, body-length, AI-coauthor) are still enforced by
# pre-ship (which resolves python) and by CI's system-audit.
echo "⚠️  python not found — running basic format check only (CI enforces the full rules)"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
# Allow auto-generated merge/revert commits — git writes "Merge ..."/"Revert ..."
# subjects that aren't Conventional Commits. commit_msg_lint.py special-cases
# these too; mirror it here so a merge can't be blocked when python is absent
# (e.g. the husky hook PATH on Windows during `git merge`).
FIRST_LINE=$(printf '%s' "$COMMIT_MSG" | head -n1)
case "$FIRST_LINE" in
  "Merge "* | "Revert "*)
    echo "✅ Merge/revert commit — allowed"
    exit 0
    ;;
esac
PATTERN="^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\(.+\))?: .{1,100}"
if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo "❌ Invalid commit message format!"
  echo "   Expected: type(scope?): description"
  echo "   Valid types: feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert"
  echo "   Your message: $COMMIT_MSG"
  exit 1
fi
echo "✅ Commit message format ok (basic check)"
