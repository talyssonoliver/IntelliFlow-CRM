  "ignoreDependencies": [
    "@types/*",
    "eslint-*",
    "@opentelemetry/exporter-metrics-otlp-http",
    "@opentelemetry/exporter-trace-otlp-http",
    "@opentelemetry/instrumentation",
    "@opentelemetry/sdk-trace-node",
    "@prisma/client",
    "@prisma/adapter-pg",
    "@vitest/coverage-v8",
    "@vitejs/plugin-react",
    "postcss",
    "axe-core",
    "vitest-axe",
    "cspell",
    "license-checker",
    "madge",
    "markdownlint-cli",
    "pino-pretty",
    "dotenv",
    "@intelliflow/*"
  ],
  "ignoreExportsUsedInFile": true,
  "includeEntryExports": true
}
