{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "lighthouserc.js",
        "lighthouserc.authenticated.js",
        "tools/**/*.ts",
        "tools/**/*.js",
        "scripts/**/*.ts",
        "scripts/**/*.js",
        "tests/setup.ts",
        "tests/**/setup.ts",
        "tests/**/vitest.config.ts",
        "tests/**/*.test.ts",
        "tests/**/*.spec.ts",
        "infra/**/*.ts",
        "artifacts/benchmarks/run-baseline-benchmark.ts",
        "artifacts/benchmarks/integrate-k6-results.ts",
        "artifacts/benchmarks/generate-performance-report.ts",
        "artifacts/benchmarks/run-accuracy-benchmark.ts"
      ],
      "project": ["**/*.ts"]
    },
    "apps/web": {
      "entry": [
        "src/app/**/page.tsx",
        "src/app/**/layout.tsx",
        "src/app/**/route.ts",
        "src/app/**/loading.tsx",
        "src/app/**/error.tsx",
        "src/app/not-found.tsx",
        "src/app/global-error.tsx"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/api": {
      "entry": ["src/index.ts", "src/main.ts", "src/ws-server.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/ai-worker": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/project-tracker": {
      "entry": [
        "app/**/page.tsx",
        "app/**/layout.tsx",
        "app/**/route.ts",
        "scripts/**/*.ts"
      ],
      "project": ["**/*.{ts,tsx}"]
    },
    "apps/workers/*": {
      "entry": ["src/main.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/workers/shared": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/search": {
      "entry": [
        "src/index.ts",
        "src/retrieval.ts",
        "src/indexer.ts",
        "src/worker.ts"
      ],
      "project": ["src/**/*.ts"]
    },
    "packages/ui": {
      "entry": ["src/index.ts", "src/**/*.stories.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/validators": {
      "entry": [
        "src/{index,lead,contact,account,opportunity,task,ticket,common,config,base-schemas,ai-review,case,timeline}.ts"
      ],
      "project": ["src/**/*.ts"]
    }
  },
  "ignore": [
    "**/dist/**",
    "**/coverage/**",
    "**/.next/**",
    "**/generated/**",
    "**/.tsup/**",
    "**/migrations/**",
    "artifacts/misc/**/*.ts",
    "tools/integrations/**/*.ts",
    "tests/mocks/**",
    "tests/utils/**",
    "tests/architecture/**",
    "tests/a11y/mocks/**",
    "apps/web/src/test-utils/**",
    "apps/web/src/test/mocks/**",
    "apps/web/src/**/__tests__/**",
    "apps/ai-worker/src/test/mocks/**",
    "apps/ai-worker/src/agents/**",
    "apps/ai-worker/src/examples/**",
    "packages/db/prisma/schema-audit.prisma",
    "packages/db/prisma/seed-ids.ts",
    "apps/api/src/tracing/example.ts",
    "apps/api/src/shared/e2e-type-safety-test.ts",
    "apps/api/src/shared/performance-benchmark.ts",
    "tools/perf/lighthouse.config.js",
    "tests/integration/setup.ts",
    "tests/e2e/utils/**",
    "tests/e2e/fixtures/**",
    "apps/project-tracker/lib/api.ts",
    "apps/project-tracker/lib/data-validator.ts",
    "apps/project-tracker/scripts/**",
    "apps/web/src/components/governance/governance-sidebar.tsx",
    "apps/web/src/components/governance/index.ts",
    "apps/web/src/components/settings/settings-sidebar.tsx",
    "apps/web/src/components/settings/index.ts",
    "apps/web/src/components/pricing/pricing-calculator.tsx",
    "apps/web/src/test/fixtures/**",
    "tools/scripts/lib/**",
    "packages/sdk/src/**"
  ],
  "tags": ["-knipignore"],
  "ignoreIssues": {
    "lighthouserc.js": ["exports"],
    "lighthouserc.authenticated.js": ["exports"],
    "tools/lighthouse/lhci-auth.js": ["exports"],
    "apps/api/src/test/**": ["exports", "types"],
    "apps/web/src/lib/test-runner/**": ["exports", "types"],
    "apps/project-tracker/lib/data-sync/orchestrator.ts": ["exports"],
