{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "apps/*/src/index.ts",
        "apps/*/src/index.tsx",
        "apps/*/app/**/*.tsx",
        "apps/*/app/**/*.ts",
        "packages/*/src/index.ts",
        "packages/*/src/index.tsx",
        "tools/**/*.ts",
        "tools/**/*.js",
        "scripts/**/*.ts",
        "scripts/**/*.js",
        "tests/setup.ts",
        "tests/**/*.test.ts",
        "tests/**/*.spec.ts",
        "infra/**/*.ts",
        "artifacts/benchmarks/run-baseline-benchmark.ts",
        "artifacts/benchmarks/integrate-k6-results.ts",
        "artifacts/benchmarks/generate-performance-report.ts",
        "artifacts/benchmarks/run-accuracy-benchmark.ts"
      ],
      "project": ["**/*.ts", "**/*.tsx"]
    }
  },
  "ignore": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/dist/**",
    "**/.tsup/**",
    "**/build/**",
    "**/node_modules/**",
    "**/.next/**",
    "**/coverage/**",
    "**/migrations/**",
    "artifacts/misc/**/*.ts",
    "tools/integrations/**/*.ts",
    "tests/mocks/**",
    "tests/utils/**",
    "tests/architecture/**",
    "apps/web/src/test-utils/**",
    "apps/web/src/test/mocks/**",
    "apps/web/src/**/__tests__/**",
    "apps/ai-worker/src/test/mocks/**",
    "apps/ai-worker/src/agents/**",
    "apps/ai-worker/src/examples/**",
    "packages/db/prisma/schema-audit.prisma",
    "packages/db/prisma/seed-ids.ts",
    "apps/api/src/tracing/example.ts",
    "apps/api/src/shared/e2e-type-safety-test.ts",
    "apps/api/src/shared/performance-benchmark.ts",
    "tools/perf/lighthouse.config.js",
    "tests/integration/setup.ts",
    "tests/e2e/utils/**",
    "tests/e2e/fixtures/**",
    "artifacts/benchmarks/**/*.json",
    "artifacts/benchmarks/**/*.html",
    "apps/project-tracker/lib/api.ts",
    "apps/project-tracker/lib/data-validator.ts",
    "apps/project-tracker/scripts/**",
    "packages/validators/src/**",
    "tools/scripts/lib/**",
    "packages/sdk/src/**"
  ],
  "ignoreIssues": {
    "apps/api/src/test/**": ["exports", "types"],
    "apps/web/src/lib/test-runner/**": ["exports", "types"],
    "apps/project-tracker/lib/data-sync/orchestrator.ts": ["exports"],
    "apps/project-tracker/lib/data-sync/validation.ts": ["exports"]
  },
  "ignoreDependencies": [
    "@types/*",
    "eslint-*",
    "prettier",
    "husky",
    "lint-staged",
    "turbo",
    "@changesets/cli",
    "tsx",
    "vitest",
    "@vitest/*",
    "@playwright/test",
    "class-variance-authority",
    "clsx",
    "tailwind-merge",
    "@radix-ui/*",
    "autoprefixer",
    "postcss",
    "depcheck",
    "dependency-cruiser",
    "ts-node",
    "papaparse",
    "pino-pretty",
    "zod-to-json-schema",
    "js-yaml",
    "dotenv",
    "zod",
    "@intelliflow/*",
    "docker-compose"
  ],
  "ignoreExportsUsedInFile": true,
  "includeEntryExports": true
}
