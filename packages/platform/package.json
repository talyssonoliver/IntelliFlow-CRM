{
  "name": "@intelliflow/platform",
  "version": "0.1.0",
  "private": true,
  "description": "Platform utilities for IntelliFlow CRM (feature flags, rollout primitives)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./feature-flags": {
      "types": "./dist/feature-flags/index.d.ts",
      "import": "./dist/feature-flags/index.mjs",
      "require": "./dist/feature-flags/index.js"
    },
    "./resilience": {
      "types": "./dist/resilience/index.d.ts",
      "import": "./dist/resilience/index.mjs",
      "require": "./dist/resilience/index.js"
    },
    "./workflow": {
      "types": "./dist/workflow/index.d.ts",
      "import": "./dist/workflow/index.mjs",
      "require": "./dist/workflow/index.js"
    },
    "./realtime": {
      "types": "./dist/realtime/index.d.ts",
      "import": "./dist/realtime/index.mjs",
      "require": "./dist/realtime/index.js"
    },
    "./queues": {
      "types": "./dist/queues/index.d.ts",
      "import": "./dist/queues/index.mjs",
      "require": "./dist/queues/index.js"
    },
    "./queues/types": {
      "types": "./dist/queues/types.d.ts",
      "import": "./dist/queues/types.mjs",
      "require": "./dist/queues/types.js"
    },
    "./queues/connection": {
      "types": "./dist/queues/connection.d.ts",
      "import": "./dist/queues/connection.mjs",
      "require": "./dist/queues/connection.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/feature-flags/index.ts src/resilience/index.ts src/workflow/index.ts src/realtime/index.ts src/queues/index.ts src/queues/types.ts src/queues/connection.ts --format cjs,esm --experimental-dts",
    "dev": "tsup src/index.ts src/feature-flags/index.ts src/resilience/index.ts src/workflow/index.ts src/realtime/index.ts src/queues/index.ts src/queues/types.ts src/queues/connection.ts --format cjs,esm --experimental-dts --watch",
    "clean": "rm -rf dist .turbo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.3",
    "@bull-board/ui": "^6.20.3",
    "@intelliflow/domain": "workspace:*",
    "bullmq": "^5.76.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@intelliflow/typescript-config": "workspace:*",
    "@types/node": "^25.3.2",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.16"
  }
}
