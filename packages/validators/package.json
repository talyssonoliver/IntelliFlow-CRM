{
  "name": "@intelliflow/validators",
  "version": "0.1.0",
  "private": true,
  "description": "Zod validation schemas for IntelliFlow CRM",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./required-url": {
      "types": "./dist/required-url.d.ts",
      "import": "./dist/required-url.mjs",
      "require": "./dist/required-url.js"
    },
    "./lead": {
      "types": "./dist/lead.d.ts",
      "import": "./dist/lead.mjs",
      "require": "./dist/lead.js"
    },
    "./contact": {
      "types": "./dist/contact.d.ts",
      "import": "./dist/contact.mjs",
      "require": "./dist/contact.js"
    },
    "./account": {
      "types": "./dist/account.d.ts",
      "import": "./dist/account.mjs",
      "require": "./dist/account.js"
    },
    "./opportunity": {
      "types": "./dist/opportunity.d.ts",
      "import": "./dist/opportunity.mjs",
      "require": "./dist/opportunity.js"
    },
    "./task": {
      "types": "./dist/task.d.ts",
      "import": "./dist/task.mjs",
      "require": "./dist/task.js"
    },
    "./ticket": {
      "types": "./dist/ticket.d.ts",
      "import": "./dist/ticket.mjs",
      "require": "./dist/ticket.js"
    },
    "./common": {
      "types": "./dist/common.d.ts",
      "import": "./dist/common.mjs",
      "require": "./dist/common.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "import": "./dist/env.mjs",
      "require": "./dist/env.js"
    },
    "./base-schemas": {
      "types": "./dist/base-schemas.d.ts",
      "import": "./dist/base-schemas.mjs",
      "require": "./dist/base-schemas.js"
    },
    "./ai-review": {
      "types": "./dist/ai-review.d.ts",
      "import": "./dist/ai-review.mjs",
      "require": "./dist/ai-review.js"
    },
    "./case": {
      "types": "./dist/case.d.ts",
      "import": "./dist/case.mjs",
      "require": "./dist/case.js"
    },
    "./help-article": {
      "types": "./dist/help-article.d.ts",
      "import": "./dist/help-article.mjs",
      "require": "./dist/help-article.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/required-url.ts src/lead.ts src/contact.ts src/account.ts src/opportunity.ts src/task.ts src/ticket.ts src/common.ts src/env.ts src/base-schemas.ts src/ai-review.ts src/case.ts src/help-article.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/required-url.ts src/lead.ts src/contact.ts src/account.ts src/opportunity.ts src/task.ts src/ticket.ts src/common.ts src/env.ts src/base-schemas.ts src/ai-review.ts src/case.ts src/help-article.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist .turbo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@intelliflow/domain": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@intelliflow/typescript-config": "workspace:*",
    "@types/node": "^25.9.1",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.7"
  }
}
