{
  "name": "@intelliflow/observability",
  "version": "0.1.0",
  "private": true,
  "description": "Observability layer for IntelliFlow CRM - OpenTelemetry, logging, and metrics",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./tracer": {
      "types": "./dist/tracer.d.ts",
      "import": "./dist/tracer.mjs",
      "require": "./dist/tracer.js"
    },
    "./tracing": {
      "types": "./dist/tracing.d.ts",
      "import": "./dist/tracing.mjs",
      "require": "./dist/tracing.js"
    },
    "./metrics": {
      "types": "./dist/metrics.d.ts",
      "import": "./dist/metrics.mjs",
      "require": "./dist/metrics.js"
    },
    "./logging": {
      "types": "./dist/logging.d.ts",
      "import": "./dist/logging.mjs",
      "require": "./dist/logging.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/tracer.ts src/tracing.ts src/metrics.ts src/logging.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/tracer.ts src/tracing.ts src/metrics.ts src/logging.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist .turbo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.73.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "0.215.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.215.0",
    "@opentelemetry/instrumentation": "0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-node": "0.215.0",
    "@opentelemetry/sdk-trace-base": "2.7.0",
    "@opentelemetry/sdk-trace-node": "2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@intelliflow/typescript-config": "workspace:*",
    "@types/node": "^25.3.2",
    "@vitest/coverage-v8": "^4.0.16",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.16"
  }
}
