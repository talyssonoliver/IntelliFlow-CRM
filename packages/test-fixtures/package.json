{
  "name": "@intelliflow/test-fixtures",
  "version": "0.1.0",
  "private": true,
  "description": "Shared test fixture constants (tenant/owner/user UUIDs, etc.) for IntelliFlow CRM tests. Consumed from source — no build step.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./ids": "./src/ids.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\""
  },
  "devDependencies": {
    "@intelliflow/typescript-config": "workspace:*",
    "typescript": "^5.3.0"
  }
}
