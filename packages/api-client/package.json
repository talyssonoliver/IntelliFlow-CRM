{
  "name": "@intelliflow/api-client",
  "version": "0.1.0",
  "private": true,
  "description": "Type-safe tRPC API client for IntelliFlow CRM",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm",
    "dev": "tsup src/index.ts --format cjs,esm --watch",
    "clean": "rm -rf dist .turbo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@intelliflow/api": "workspace:*",
    "@intelliflow/validators": "workspace:*",
    "@tanstack/react-query": "^5.100.10",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    }
  },
  "devDependencies": {
    "@intelliflow/typescript-config": "workspace:*",
    "@trpc/server": "^11.17.0",
    "@types/node": "^25.3.2",
    "@types/react": "19.2.14",
    "eslint": "^10.0.2",
    "react": "19.2.6",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.16"
  }
}
