{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": "../../..",
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "outDir": "../dist-seed-typecheck",
    "types": ["node"]
  },
  "include": [
    "seed-help-articles.ts",
    "seed-help-articles.cli.ts",
    "scripts/**/*.ts",
    "data/help-articles.snapshot.json",
    "../src/seed-ids.ts",
    "../generated/prisma/**/*.ts",
    "../../../apps/web/src/lib/support/help-articles.ts",
    "../../../apps/web/src/lib/support/help-categories.ts"
  ],
  "exclude": ["**/__tests__/**", "**/*.test.ts"]
}
