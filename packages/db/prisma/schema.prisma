  summary             String?       @db.Text
  predictedPriority   CasePriority?
  suggestedResolution String?       @db.Text
  recommendations     Json?         // Array<string>
  // Provenance (nullable — partial upserts may omit, last-writer-wins)
  modelVersion        String?
  generatedAt         DateTime?     @default(now())
  source              String?       @default("llm") // 'llm' | 'fallback'
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([tenantId])
  @@map("case_ai_insights")
