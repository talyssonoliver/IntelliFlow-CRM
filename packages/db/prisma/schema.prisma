// IntelliFlow CRM - Prisma Schema
// This schema is AI-optimized with pgvector for embeddings

generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  engineType      = "client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ============================================
// MULTI-TENANCY
// ============================================

model Tenant {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Relations — all reverse relation fields @ignore'd to shrink generated Tenant.ts
  // (FK constraints preserved in DB; child-side relations untouched)
  users                User[]                     @ignore
  leads                Lead[]                     @ignore
  contacts             Contact[]                  @ignore
  accounts             Account[]                  @ignore
  opportunities        Opportunity[]              @ignore
  tasks                Task[]                     @ignore
  tickets              Ticket[]                   @ignore
  auditLogs            AuditLog[]                 @ignore
  auditLogEntries      AuditLogEntry[]            @ignore
  calendarEvents       CalendarEvent[]            @ignore
  dealRenewals         DealRenewal[]              @relation("DealRenewals") @ignore
  contactNotes         ContactNote[]              @ignore
  conversationRecords  ConversationRecord[]       @ignore
  pipelineStageConfigs PipelineStageConfig[]      @ignore
  chainVersions        ChainVersion[]             @ignore
  domainEvents         DomainEvent[]              @ignore
  aiOutputReviews      AIOutputReview[]           @ignore
  experiments          Experiment[]               @ignore
  slaPolicies          SLAPolicy[]                @ignore
  aiScores             AIScore[]                  @ignore
  teamMessages         TeamMessage[]              @ignore
  pipelineSnapshots    PipelineSnapshot[]         @ignore
  trafficSources       TrafficSource[]            @ignore
  growthMetrics        GrowthMetric[]             @ignore
  ticketNextSteps      TicketNextStep[]           @ignore
  relatedTickets       RelatedTicket[]            @ignore
  ticketAIInsights     TicketAIInsight[]          @ignore
  salesPerformances    SalesPerformance[]         @ignore
  teams                Team[]                     @ignore
  teamMembers          TeamMember[]               @ignore
  emailTemplates       EmailTemplate[]            @ignore
  feedbackSurveys      FeedbackSurvey[]           @ignore
  accountHealthScores  AccountHealthScore[]       @ignore
  agentSkills          AgentSkill[]               @ignore
  slABreaches          SLABreach[]                @ignore
  escalationHistories  EscalationHistory[]        @ignore
  reportDefinitions    ReportDefinition[]         @ignore
  aiInsights           AIInsight[]                @ignore
  performanceMetrics   PerformanceMetric[]        @ignore
  modules              TenantModule[]             @ignore
  dealProducts         DealProduct[]              @ignore
  setupInstalments     SetupInstalment[]          @ignore
  dealFiles            DealFile[]                 @ignore
  agentActions         AgentAction[]              @ignore
  activityEvents       ActivityEvent[]            @ignore
  contactActivities    ContactActivity[]          @ignore
  messageRecords       MessageRecord[]            @ignore
  toolCallRecords      ToolCallRecord[]           @ignore
  securityEvents       SecurityEvent[]            @ignore
  apiUsageRecords      APIUsageRecord[]           @ignore
  apiKeys              APIKey[]                   @ignore
  businessRules        BusinessRule[]             @ignore
  businessRuleExecs    BusinessRuleExecution[]    @ignore
  chatConversations    ChatConversation[]         @ignore
  dashboardConfigs     DashboardConfig[]          @ignore
  dealsWonMetrics      DealsWonMetric[]           @ignore
  documentAccessLogs   DocumentAccessLog[]        @ignore
  documentShares       DocumentShare[]            @ignore
  documents            Document[]                 @ignore
  emailAttachments     EmailAttachment[]          @ignore
  reportExecutions     ReportExecution[]          @ignore
  reportSchedules      ReportSchedule[]           @ignore
  slaNotifications     SLANotification[]          @ignore
  ticketAttachments    TicketAttachment[]         @ignore
  ticketCategories     TicketCategory[]           @ignore
  webhookDeliveries    WebhookDelivery[]          @ignore
  webhookEndpoints     WebhookEndpoint[]          @ignore
  workflowDefinitions  WorkflowDefinition[]       @ignore
  workflowExecutions   WorkflowExecution[]        @ignore
  leadActivities       LeadActivity[]             @ignore
  leadNotes            LeadNote[]                 @ignore
  leadFiles            LeadFile[]                 @ignore
  appointments         Appointment[]              @ignore
  appointmentAttendees AppointmentAttendee[]      @ignore
  appointmentCases     AppointmentCase[]          @ignore
  cases                Case[]                     @ignore
  caseTasks            CaseTask[]                 @ignore
  ticketActivities     TicketActivity[]           @ignore
  userRoleAssignments  UserRoleAssignment[]       @ignore
  userPermissions      UserPermission[]           @ignore
  leadAIInsights       LeadAIInsight[]            @ignore
  contactAIInsights    ContactAIInsight[]         @ignore
  accountAIInsights    AccountAIInsight[]         @ignore
  caseAIInsights       CaseAIInsight[]            @ignore
  contactReplyDrafts   ContactReplyDraft[]        @ignore
  autoResponseDrafts   AutoResponseDraft[]        @ignore
  emailRecords         EmailRecord[]              @ignore
  chatMessages         ChatMessage[]              @ignore
  callRecords          CallRecord[]               @ignore
  agentAvailabilities  AgentAvailability[]        @ignore
  routingRules         RoutingRule[]              @ignore
  routingAudits        RoutingAudit[]             @ignore
  notifications        Notification[]             @ignore
  notifPreferences     NotificationPreference[]   @ignore
  notifTemplates       NotificationTemplate[]     @ignore
  notificationDLQ      NotificationDLQ[]          @ignore
  leadConversionAudits LeadConversionAudit[]      @ignore
  caseDocuments        CaseDocument[]             @ignore
  caseDocumentACLs     CaseDocumentACL[]          @ignore
  caseDocumentAudits   CaseDocumentAudit[]        @ignore
  calendars            Calendar[]                 @ignore
  activityReactions    ActivityReaction[]         @ignore
  activityComments     ActivityComment[]          @ignore
  sessions             Session[]                  @ignore
  helpArticles         HelpArticle[]              @ignore
  articleSections      ArticleSection[]           @ignore
  articleFeedback      ArticleFeedback[]          @ignore
  leadStageConfigs       LeadStageConfig[]        @ignore
  leadScoringRules       LeadScoringRule[]        @ignore
  leadCustomFields       LeadCustomField[]        @ignore
  leadAutomationSettings LeadAutomationSetting[]  @ignore
  contactDuplicateRules  ContactDuplicateRule[]   @ignore
  contactRequiredFields  ContactRequiredField[]   @ignore
  contactTags            ContactTag[]             @ignore
  contactAutomationSettings ContactAutomationSetting[] @ignore
  dealWinLossReasons     DealWinLossReason[]      @ignore
  dealScoringRules       DealScoringRule[]        @ignore
  dealDuplicateRules     DealDuplicateRule[]      @ignore
  dealRequiredFields     DealRequiredField[]      @ignore
  dealTags               DealTag[]                @ignore
  dealAutomationSettings DealAutomationSetting[]  @ignore
  ticketDuplicateRules   TicketDuplicateRule[]    @ignore
  ticketRequiredFields   TicketRequiredField[]    @ignore
  ticketTags             TicketTag[]              @ignore
  ticketAutomationSettings TicketAutomationSetting[] @ignore
  aiMonitoringEvents     AIMonitoringEvent[]      @ignore
  customNodeTypes        CustomNodeType[]         @ignore
  customActionHandlers   CustomActionHandler[]    @ignore
  documentGeneralConfigs DocumentGeneralConfig[]  @ignore
  documentDuplicateRules DocumentDuplicateRule[]  @ignore
  documentRequiredFields DocumentRequiredField[]  @ignore
  documentTags           DocumentTag[]            @ignore
  documentTypeDefinitions DocumentTypeDefinition[] @ignore
  documentAutomationSettings DocumentAutomationSetting[] @ignore
  documentRetentionPolicies DocumentRetentionPolicy[] @ignore
  caseSettings              CaseSettings[]            @ignore
  caseDuplicateRules        CaseDuplicateRule[]       @ignore
  caseRequiredFields        CaseRequiredField[]       @ignore
  caseTags                  CaseTag[]                 @ignore
  caseAutomationSettings    CaseAutomationSetting[]   @ignore
  appointmentSettings       AppointmentSettings[]     @ignore
  reportSettings            ReportSettings[]          @ignore
  toolEnablements           TenantToolEnablement[]    // H6: per-tenant tool on/off
  aiConfigs                 TenantAIConfig[]           // M8/M9: per-tenant LLM tier overrides
  memoryPolicy              TenantMemoryPolicy?        // P2.7: per-tenant memory retention
  goalDefault               TenantGoalDefault?         // IFC-211: org-wide default daily goal

  @@index([slug])
  @@index([status])
  @@map("tenants")
}

// H6 — Per-tenant tool enable/disable (ADR-006 tools)
model TenantToolEnablement {
  id        String   @id @default(cuid())
  tenantId  String
  toolName  String   // e.g. "search_leads", "create_case"
  enabled   Boolean  @default(true)
  reason    String?  // optional: why it was disabled (audit)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, toolName])
  @@index([tenantId, enabled])
  @@map("tenant_tool_enablement")
}

// M8/M9 — Per-tenant LLM tier override for createLLM(purpose, tier)
// P2.8 — rateLimitPerMinute added: per-tenant rate-limit override; null falls back to the
//        global AI_RATE_LIMIT_PER_MINUTE env var (see apps/ai-worker/src/config/ai.config.ts).
model TenantAIConfig {
  id                 String   @id @default(cuid())
  tenantId           String
  purpose            String   // "scoring" | "qualification" | "email" | "reasoning" | "structured" | "rag"
  tier               String   // "free" | "standard" | "premium"
  temperature        Float?
  maxTokens          Int?
  rateLimitPerMinute Int?     // P2.8: null = use global env default
  // Absent row = use factory default. A row overrides the default tier for that purpose.
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, purpose])
  @@index([tenantId])
  @@map("tenant_ai_config")
}

// P2.7 — Per-tenant retention policy for conversation/memory artifacts.
// Absent row = platform default. Pruning job (memory-retention.job.ts) joins
// against this model daily. See docs/architecture/adr/schema-proposal-2026-04-19-tenant-memory-and-rate-limits.md.
model TenantMemoryPolicy {
  id                           String   @id @default(cuid())
  tenantId                     String   @unique
  /// Delete ConversationRecord + MessageRecord older than N days (null = never).
  conversationRetentionDays    Int?
  /// Delete ChainVersion rows archived >= N days (null = keep forever).
  chainVersionRetentionDays    Int?
  /// Delete AIMonitoringEvent rows older than N days (null = keep forever).
  monitoringEventRetentionDays Int?
  /// If true, PII-scrub conversation bodies at the retention boundary rather than delete.
  scrubRatherThanDelete        Boolean  @default(false)
  /// Optional free-text justification surfaced in audit logs.
  reason                       String?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  tenant                       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tenant_memory_policy")
}

/// IFC-211: Tenant-wide default daily goal. Applied by home.getDailyGoal when
/// User.preferences.dailyGoal is unset. Single row per tenant (enforced via
/// @unique on tenantId). Written by home.setOrgGoalDefault (admin-only).
model TenantGoalDefault {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  /// One of: 'revenue' | 'calls' | 'meetings' | 'tasks' | 'custom' (validated by Zod at the router boundary).
  goalType    String
  targetValue Int
  label       String?
  customUnit  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  /// actorId of the admin who last upserted this default — surfaced in audit log payloads.
  updatedBy   String?

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tenant_goal_default")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

// IFC-208: Plan Tiers & Module Registry
enum PlanTier {
  STARTER
  PROFESSIONAL
  ENTERPRISE
  CUSTOM
}

enum CRMModule {
  CORE_CRM
  LEGAL
  SUPPORT
  AI_INTELLIGENCE
  ANALYTICS
  COMMERCE
}

/// Tracks which modules are enabled for each tenant.
/// Modules can be enabled via plan tier or à la carte purchase.
model TenantModule {
  id         String     @id @default(cuid())
  tenantId   String
  moduleId   CRMModule
  enabled    Boolean    @default(true)
  enabledAt  DateTime   @default(now())
  disabledAt DateTime?

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleId])
  @@index([tenantId])
  @@map("tenant_modules")
}

// ============================================
// AUTH & USERS
// ============================================

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  givenName        String?   // First name (from OAuth given_name)
  familyName       String?   // Last name (from OAuth family_name)
  avatarUrl        String?
  role             UserRole  @default(USER)
  stripeCustomerId String?   @unique // Stripe customer ID for billing
  preferences      Json?     // User preferences (pinned items, dashboard settings)
  timezone         String?   @default("Europe/London") // IANA timezone identifier (e.g. "America/New_York")
  locale           String?   @default("en-US") // BCP 47 locale (e.g. "en-US", "pt-BR")

  // Profile contact info
  phone            String?
  company          String?
  department       String?
  location         String?
  website          String?
  bio              String?

  // OAuth / sign-in metadata
  provider         String?   // e.g. "google", "github", "email"
  emailVerified    Boolean   @default(false)
  lastSignInAt     DateTime?
  signInCount      Int       @default(0)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Multi-tenancy
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  leads               Lead[]
  contacts            Contact[]
  accounts            Account[]
  opportunities       Opportunity[]
  tasks               Task[]  @relation("TaskOwner")
  tasksAssigned       Task[]  @relation("TaskAssignee")
  aiScores            AIScore[]
  auditLogs           AuditLog[]
  auditLogEntries     AuditLogEntry[]
  conversationRecords ConversationRecord[]
  casesAssigned       Case[]              @relation("CaseAssignee")
  caseTasksAssigned   CaseTask[]          @relation("CaseTaskAssignee")
  caseSettingsAsAutoAssignee CaseSettings[] @relation("CaseSettingsAutoAssignee")

  // Custom calendars owned by this user
  calendars           Calendar[]
  mfaSettings         UserMfaSettings?
  sessions            Session[]

  @@index([email])
  @@index([role])
  @@index([tenantId])
  @@index([stripeCustomerId])
  @@map("users")
}

model UserMfaSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId        String
  totpEnabled     Boolean  @default(false)
  totpSecret      String?
  smsEnabled      Boolean  @default(false)
  smsPhone        String?
  emailEnabled    Boolean  @default(false)
  backupCodes     String[] @default([])
  backupCodesGeneratedAt DateTime?
  enabledAt       DateTime?
  lastVerifiedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([tenantId])
  @@map("user_mfa_settings")
}

/// User session persistence model (Fix #9 — session.service.ts DB persistence)
model Session {
  id           String   @id
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deviceInfo   Json     @default("{}")
  ipAddress    String?  @db.VarChar(45)
  userAgent    String?
  refreshToken String?
  rememberMe   Boolean  @default(false)
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
  @@index([expiresAt])
  @@map("sessions")
}

enum UserRole {
  USER
  ADMIN
  MANAGER
  SALES_REP
}

// ============================================
// CRM CORE ENTITIES
// ============================================

model Lead {
  id              String      @id @default(cuid())
  // ADR-007: data classification tier (drives retention / legal-hold policy).
  dataClassification DataClassification @default(INTERNAL)
  email           String
  firstName       String?
  lastName        String?
  company         String?
  title           String?
  phone           String?
  source          LeadSource  @default(WEBSITE)
  status          LeadStatus  @default(NEW)
  score           Int         @default(0)
  location        String?
  website         String?
  avatarUrl       String?
  lastContactedAt DateTime?
  estimatedValue  Int?        @default(0)
  tags            String[]    @default([])
  isStarred       Boolean     @default(false)  // PG-059: sidebar "Starred" view
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Multi-tenancy
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  ownerId       String
  owner         User        @relation(fields: [ownerId], references: [id])
  contact       Contact?
  aiScores      AIScore[]
  aiInsights    LeadAIInsight[]  // M2: compound unique (leadId, tenantId) — one row per tenant
  tasks         Task[]
  activities              LeadActivity[]
  notes                   LeadNote[]
  files                   LeadFile[]
  experimentAssignments   ExperimentAssignment[]
  autoResponseDrafts      AutoResponseDraft[]

  // Account association (IFC-227: Company-to-Account Navigation Link)
  accountId     String?
  account       Account?  @relation("LeadAccount", fields: [accountId], references: [id], onDelete: SetNull)

  // AI Embedding for semantic search
  embedding     Unsupported("vector(1536)")?

  @@unique([email, tenantId])
  @@index([email])
  @@index([status])
  @@index([score])
  @@index([ownerId])
  @@index([tenantId])
  @@index([createdAt])
  @@index([tenantId, status, score(sort: Desc)]) // IFC-030: Lead routing queries
  @@index([tenantId, ownerId, status]) // IFC-030: Assigned lead lookups
  @@index([tenantId, ownerId, createdAt(sort: Desc)]) // HOME-PERF: Welcome summary lead counts
  @@index([tenantId, ownerId, isStarred]) // PG-059: fast "?view=starred" for current user
  @@index([accountId])
  @@map("leads")
}

/// Lead activity timeline entry (Lead 360)
model LeadActivity {
  id          String            @id @default(cuid())
  leadId      String
  lead        Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type        LeadActivityType
  title       String
  description String?
  timestamp   DateTime          @default(now())
  userId      String?
  userName    String
  sentiment   Sentiment?
  metadata    Json?
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([timestamp])
  // IFC-069: Composite index for unified activity feed
  @@index([tenantId, timestamp(sort: Desc)])
  @@map("lead_activities")
}

enum LeadActivityType {
  WEB_FORM
  EMAIL
  CALL
  MEETING
  NOTE
  SCORE_UPDATE
  STATUS_CHANGE
  QUALIFICATION
}

/// Lead notes (Lead 360)
model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  author    String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // DBA-109: Preserve DB vector columns (matching ContactNote pattern)
  embedding    Unsupported("vector(1536)")?
  searchVector Unsupported("tsvector")? @map("search_vector")

  @@index([leadId])
  @@index([createdAt])
  @@index([tenantId])
  @@map("lead_notes")
}

/// Lead file attachments (Lead 360)
model LeadFile {
  id           String   @id @default(cuid())
  leadId       String
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  name         String
  size         String
  sizeBytes    Int?
  fileType     FileType @default(OTHER)
  url          String?
  uploadedAt   DateTime @default(now())
  uploadedById String?
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([uploadedAt])
  @@index([tenantId])
  @@map("lead_files")
}

enum LeadSource {
  WEBSITE
  REFERRAL
  SOCIAL
  EMAIL
  COLD_CALL
  EVENT
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  NEGOTIATING
  UNQUALIFIED
  DISQUALIFIED
  CONVERTED
  LOST
  ARCHIVED
}

enum ContactStatus {
  ACTIVE
  INACTIVE
  PROSPECT
  CUSTOMER
  FORMER_CUSTOMER
}

model Contact {
  id            String    @id @default(cuid())
  // ADR-007: data classification tier (drives retention / legal-hold policy).
  dataClassification DataClassification @default(INTERNAL)
  // DBA-020: Changed from global @unique to tenant-scoped (prevents cross-tenant enumeration)
  email         String
  firstName     String
  lastName      String
  title         String?
  phone         String?
  department    String?
  status        ContactStatus @default(ACTIVE)

  // Extended contact fields (IFC-089 form support)
  streetAddress String?
  city          String?
  zipCode       String?
  company       String?   // Company name (may differ from linked account)
  linkedInUrl   String?
  contactType   String?   // customer, prospect, partner, vendor, investor, other
  tags          String[]  @default([])
  contactNotes  String?   @db.Text  // Free-form notes field
  lastContactedAt DateTime?  // IFC-192: Auto-updated on qualifying interactions
  avatarUrl     String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Multi-tenancy
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  ownerId       String
  owner         User      @relation(fields: [ownerId], references: [id])
  accountId     String?
  account       Account?  @relation(fields: [accountId], references: [id])
  leadId        String?   @unique
  lead          Lead?     @relation(fields: [leadId], references: [id])
  opportunities Opportunity[]
  tasks         Task[]
  activities    ContactActivity[]
  notes         ContactNote[]
  aiInsight     ContactAIInsight?
  replyDrafts   ContactReplyDraft[]
  calendarEvents CalendarEvent[]

  // AI Embedding
  embedding     Unsupported("vector(1536)")?

  // DBA-020: Tenant-scoped email uniqueness (replaces global @unique)
  @@unique([tenantId, email])
  // DBA-012: Composite unique guard prevents cross-tenant FK references
  @@unique([tenantId, id])
  @@index([email])
  @@index([ownerId])
  @@index([accountId])
  @@index([tenantId])
  // IFC-185: Composite indexes for Account router performance
  @@index([accountId, tenantId])
  @@index([accountId, createdAt(sort: Desc)])
  // IFC-192: Composite index for stale contact queries
  @@index([tenantId, lastContactedAt])
  // HOME-PERF: home.getAIInsights stale-contact query (ownerId + lastContactedAt)
  @@index([tenantId, ownerId, lastContactedAt])
  @@map("contacts")
}

model Account {
  id            String    @id @default(cuid())
  // ADR-007: data classification tier (drives retention / legal-hold policy).
  dataClassification DataClassification @default(INTERNAL)
  name          String
  website       String?
  industry      String?
  employees     Int?
  revenue       Decimal?  @db.Decimal(15, 2)
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // IFC-312: AI account scoring provenance
  score                Int?
  scoreProvenance      Json?
  scoredAt             DateTime?
  scoreModelVersion    String?
  // IFC-312: AI industry inference provenance
  industryInferredAt   DateTime?
  industryModelVersion String?
  // IFC-312 audit fix F3: per-account tags (mirrors Contact.tags). Consumed by
  // account.addTags + SuggestedTagsRow Accept flow. AccountTag model is the
  // tenant vocabulary, NOT a per-account join.
  tags                 String[]  @default([])

  // Multi-tenancy
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  ownerId       String
  owner         User      @relation(fields: [ownerId], references: [id])
  contacts      Contact[]
  opportunities Opportunity[]
  cases         Case[]
  leads         Lead[]    @relation("LeadAccount")
  aiInsight     AccountAIInsight?

  // Hierarchy: parent/child account relationships
  parentAccountId  String?
  parentAccount    Account?  @relation("AccountHierarchy", fields: [parentAccountId], references: [id], onDelete: SetNull)
  childAccounts    Account[] @relation("AccountHierarchy")

  // DBA-012: Composite unique guard prevents cross-tenant FK references
  @@unique([tenantId, id])
  @@index([name])
  @@index([ownerId])
  @@index([tenantId])
  @@index([parentAccountId])
  @@index([score])
  @@map("accounts")
}

// ─── PG-183: Account Settings ───────────────────────────────────────────────

/// Tenant-wide account hierarchy rules. One row per tenant.
model AccountHierarchyConfig {
  id                    String   @id @default(cuid())
  tenantId              String   @unique
  maxDepth              Int      @default(5)
  requireParentForTiers String[] @default([])
  preventCycles         Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("account_hierarchy_config")
}

/// Admin-configurable industry taxonomy for accounts.
model AccountIndustryOption {
  id        String   @id @default(cuid())
