  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([status])
  @@index([entityType, entityId])
  @@index([startedAt])
  @@index([tenantId])
  // DBA-125: Composite index for workflow history ordering
  @@index([workflowId, startedAt])
