/// PG-190 — AI insight per case. Written by case-insight, case-summarization,
/// case-priority-prediction, and case-resolution-suggestion chains. Mirrors
/// the AccountAIInsight provenance shape but uses the existing CasePriority
/// enum for predictedPriority and keeps provenance fields nullable so partial
/// upserts (e.g. priority-only) don't require placeholder modelVersion.
/// Restored 2026-04-26 to fix master-blocking typecheck failure (commit
/// f3fbdd1e shipped chains referencing prisma.caseAIInsight without the model).
model CaseAIInsight {
  id                  String        @id @default(cuid())
  caseId              String        @unique
  case                Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  tenantId            String
