model Opportunity {
  id            String              @id @default(cuid())
  // ADR-007: data classification tier (drives retention / legal-hold policy).
  dataClassification DataClassification @default(INTERNAL)
  name          String
  value         Decimal             @db.Decimal(15, 2)
  stage         OpportunityStage    @default(PROSPECTING)
  probability   Int                 @default(0)
  expectedCloseDate DateTime?
  description   String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  closedAt      DateTime?
  deletedAt     DateTime?

  // Multi-tenancy
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  ownerId       String
  owner         User                @relation(fields: [ownerId], references: [id])
  accountId     String
  account       Account             @relation(fields: [accountId], references: [id])
  contactId     String?
  contact       Contact?            @relation(fields: [contactId], references: [id])
  sourceLeadId  String?
  tasks         Task[]
  products      DealProduct[]
  files         DealFile[]
  activities    ActivityEvent[]

  // IFC-314: Leangency portal delivery sync (14-day flow) — CRM mirrors billing.
  // The portal owns the delivery phase/clock; these fields drive the CRM→portal push.
  deliveryTier  DeliveryTier?
  tenantSlug    String?            // target portal tenant slug (push routing)
  setupInstalments SetupInstalment[]

  @@index([stage])
  @@index([ownerId])
  @@index([accountId])
  @@index([tenantId])
  @@index([expectedCloseDate])
  @@index([sourceLeadId])
  // IFC-185: Composite indexes for Account router performance
  @@index([accountId, tenantId])
  @@index([accountId, stage])
  @@index([accountId, createdAt(sort: Desc)])
  // IFC-192: Composite index for stale contact EXISTS subquery
  @@index([contactId, stage])
  // HOME-PERF: Composite index for getWelcomeSummary deal trend queries
  @@index([tenantId, ownerId, stage, closedAt])
  // HOME-PERF: home.getAIInsights deals-at-risk query (stage NOT IN, updatedAt <)
  @@index([tenantId, ownerId, stage, updatedAt])
  @@index([deletedAt])
  @@map("opportunities")
}

enum OpportunityStage {
  PROSPECTING
  QUALIFICATION
  NEEDS_ANALYSIS
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

