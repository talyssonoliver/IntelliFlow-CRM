  @@index([aggregateType, aggregateId])
  @@index([status])
  @@index([occurredAt])
  @@index([tenantId])
  @@index([status, nextRetryAt])
  // DBA-125: Composite index for tenant-scoped event processing
  @@index([tenantId, status])
  @@map("domain_events")
}

enum EventStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  DEAD_LETTER
  ARCHIVED
}

// ============================================
// LEGAL DOMAIN - APPOINTMENTS
// ============================================

model Appointment {
  id                  String              @id @default(cuid())
  title               String
  description         String?
  startTime           DateTime
  endTime             DateTime
  timezone            String?             /// IANA timezone of the event (e.g. "America/New_York"). Null = UTC.
  appointmentType     AppointmentType     @default(MEETING)
  status              AppointmentStatus   @default(SCHEDULED)
  location            String?
  notes               String?

  // Buffer times
  bufferMinutesBefore Int                 @default(0)
  bufferMinutesAfter  Int                 @default(0)

  // Recurrence (stored as JSON)
  recurrence          Json?
  parentAppointmentId String?
  parentAppointment   Appointment?        @relation("RecurringSeries", fields: [parentAppointmentId], references: [id])
  recurringInstances  Appointment[]       @relation("RecurringSeries")

  // External calendar integration
  externalCalendarId  String?

  // Reminder
  reminderMinutes     Int?

  // Timestamps
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  cancelledAt         DateTime?
  completedAt         DateTime?
  cancellationReason  String?

  // Multi-tenancy
  tenantId            String
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  organizerId         String
  calendarId          String?
  calendar            Calendar?           @relation(fields: [calendarId], references: [id], onDelete: SetNull)
  attendees           AppointmentAttendee[]
  linkedCases         AppointmentCase[]

  @@index([tenantId])
  @@index([organizerId])
  @@index([status])
  @@index([startTime])
  @@index([endTime])
  @@index([appointmentType])
  @@index([startTime, endTime])
  @@index([externalCalendarId])
  @@index([calendarId])
  @@map("appointments")
}

model AppointmentAttendee {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  userId        String
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([appointmentId, userId])
  @@index([userId])
  @@index([tenantId])
  @@map("appointment_attendees")
}

model AppointmentCase {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  caseId        String
  case          Case        @relation("CaseAppointments", fields: [caseId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([appointmentId, caseId])
  @@index([caseId])
  @@index([tenantId])
  @@map("appointment_cases")
}

enum AppointmentType {
  MEETING
  CALL
  HEARING
  CONSULTATION
  DEPOSITION
  OTHER
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ============================================
// LEGAL CASES - PG-138 Case Management
// ============================================

model Case {
  id           String       @id @default(cuid())
  title        String
  description  String?      @db.Text
  status       CaseStatus   @default(OPEN)
  priority     CasePriority @default(MEDIUM)
  deadline     DateTime?
  timezone     String?      /// IANA timezone for deadlines (e.g. "America/New_York"). Null = UTC.
  jurisdiction String?      /// Legal jurisdiction (e.g. "US-NY", "UK-England"). Drives court-time display.
  clientId     String
  assignedTo   String
  resolution   String?      @db.Text
  parties      Json?
  closedAt     DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Multi-tenancy
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  client       Account          @relation(fields: [clientId], references: [id])
  assignee     User             @relation("CaseAssignee", fields: [assignedTo], references: [id])
  tasks        CaseTask[]
  appointments AppointmentCase[] @relation("CaseAppointments")
  aiInsight    CaseAIInsight?

  @@index([status])
  @@index([priority])
  @@index([clientId])
  @@index([assignedTo])
  @@index([deadline])
  @@index([status, deadline])
  @@index([tenantId])
  @@map("cases")
}

/// PG-190 — per-tenant case module settings (case prefix, default priority, auto-assign policy).
model CaseSettings {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  casePrefix        String   @default("CASE-")
  defaultPriority   String   @default("MEDIUM")
  autoAssignEnabled Boolean  @default(false)
  autoAssignUserId  String?
  autoAssignUser    User?    @relation("CaseSettingsAutoAssignee", fields: [autoAssignUserId], references: [id], onDelete: SetNull)
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([autoAssignUserId])
  @@map("case_settings")
}

/// PG-190 v2 — per-tenant case duplicate-detection rules.
model CaseDuplicateRule {
  id              String   @id @default(cuid())
  tenantId        String
  field           String
  matchStrategy   String
  collisionAction String   @default("warn")
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, field, matchStrategy])
  @@index([tenantId])
  @@map("case_duplicate_rules")
}

/// PG-190 v2 — per-tenant case required-field policy (one row per enforced field).
model CaseRequiredField {
  id         String   @id @default(cuid())
  tenantId   String
  fieldKey   String
  isRequired Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, fieldKey])
  @@index([tenantId])
  @@map("case_required_fields")
}

/// PG-190 v2 — per-tenant case tags (name + color token).
model CaseTag {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  colorToken  String   @default("slate")
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("case_tags")
}

/// PG-190 v2 — per-tenant case automation + AI toggle singleton.
/// AI toggles default FALSE per the module-settings playbook (explicit opt-in).
model CaseAutomationSetting {
  id                          String   @id @default(cuid())
  tenantId                    String   @unique
  // Workflow automation
  autoEscalateOverdue         Boolean  @default(false)
  notifyOnAssignmentChange    Boolean  @default(true)
  notifyOnDeadlineApproaching Boolean  @default(true)
  notifyOnStatusChange        Boolean  @default(false)
  // Data hygiene
  notifyOnDuplicate           Boolean  @default(true)
  restrictTagCreationToAdmins Boolean  @default(false)
  preventDeleteWithOpenTasks  Boolean  @default(true)
  // AI & Intelligence — default FALSE per playbook
  aiCaseSummarization         Boolean  @default(false)
  aiPriorityPrediction        Boolean  @default(false)
  aiResolutionSuggestion      Boolean  @default(false)
  aiTagSuggestions            Boolean  @default(false)
  aiInsightGeneration         Boolean  @default(false)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  tenant                      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("case_automation_settings")
}

/// PG-189 — per-tenant appointment / calendar module settings. Landed alongside
/// PG-190 to unblock AC-007 after the PG-189 Ralph-loop shipped the router
/// without the backing schema. See PG-190 attestation notes.
model AppointmentSettings {
  id                         String    @id @default(cuid())
  tenantId                   String    @unique
  defaultDurationMinutes     Int       @default(30)
  minDurationMinutes         Int       @default(5)
  maxDurationMinutes         Int       @default(480)
  defaultBufferBeforeMinutes Int       @default(0)
  defaultBufferAfterMinutes  Int       @default(0)
  defaultReminderMinutes     Int?      @default(15)
  primaryCalendarId          String?
  primaryCalendar            Calendar? @relation("AppointmentSettingsPrimaryCalendar", fields: [primaryCalendarId], references: [id], onDelete: SetNull)
  syncExternalCalendars      Boolean   @default(false)
  defaultTimezone            String    @default("UTC")
  tenant                     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@index([primaryCalendarId])
  @@map("appointment_settings")
}

/// PG-187 — per-tenant report defaults. Landed alongside PG-190 to unblock
/// AC-007 after the PG-187 Ralph-loop shipped the router without the backing
/// schema. See PG-190 attestation notes.
model ReportSettings {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  defaultRange      String   @default("30d")
  currency          String   @default("USD")
  scheduledDelivery Json     @default("{\"enabled\":false,\"frequency\":\"weekly\",\"dayOfWeek\":1,\"time\":\"09:00\",\"recipients\":[],\"format\":\"pdf\"}")
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("report_settings")
}

model CaseTask {
  id          String         @id @default(cuid())
  caseId      String
  title       String
  description String?        @db.Text
  dueDate     DateTime?
  status      CaseTaskStatus @default(PENDING)
  assignee    String?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  case         Case  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  assignedUser User? @relation("CaseTaskAssignee", fields: [assignee], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([status])
  @@index([assignee])
  @@index([dueDate])
  @@index([status, dueDate])
  @@index([tenantId])
  @@map("case_tasks")
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  CLOSED
  CANCELLED
}

enum CasePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CaseTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================
// SECURITY EVENTS - IFC-098 RBAC/ABAC
// ============================================

model SecurityEvent {
  id              String            @id @default(cuid())
  // DBA-029: Wire SecurityEventType enum (was String)
  eventType       SecurityEventType
  severity        SecuritySeverity  @default(INFO)
  // DBA-029: Wire EventOutcome enum (was unused)
  outcome         EventOutcome?

  // Multi-tenancy
  // DBA-007: Fixed nullable → NOT NULL to match DB constraint
  tenantId        String
  tenant          Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Actor
  actorId         String?
  actorEmail      String?
  // DBA-017: IP addresses capped at 45 chars for IPv6-mapped-IPv4
  actorIp         String?           @db.VarChar(45)

  // Event details
  description     String?
  details         Json?

  // Detection flags
  detected        Boolean         @default(false)
  detectedBy      String?
  blocked         Boolean         @default(false)
  alertSent       Boolean         @default(false)

  // Timestamps
  createdAt       DateTime        @default(now())

  @@index([eventType])
  @@index([actorId])
  @@index([severity])
  @@index([tenantId])
  @@index([createdAt])
  // DBA-120: Composite indexes for security dashboard queries
  @@index([tenantId, createdAt])
  @@index([tenantId, eventType])
  @@map("security_events")
}

enum SecuritySeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EventOutcome {
  SUCCESS
  FAILURE
  DENIED
  ERROR
}

// ============================================
// TICKETS & SLA TRACKING - IFC-093
// ============================================

model Ticket {
  id                  String          @id @default(cuid())
  ticketNumber        String          @unique // T-XXXXX format
  subject             String
  description         String?
  status              TicketStatus    @default(OPEN)
  priority            TicketPriority  @default(MEDIUM)

  // Multi-tenancy
  tenantId            String
  tenant              Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // SLA Tracking
  slaPolicy           SLAPolicy       @relation(fields: [slaPolicyId], references: [id])
  slaPolicyId         String
  slaResponseDue      DateTime?       // First response due time
  slaResolutionDue    DateTime?       // Resolution due time
  slaStatus           SLAStatus       @default(ON_TRACK)
  slaBreachedAt       DateTime?       // When SLA was first breached
  firstResponseAt     DateTime?       // When first response was made
  resolvedAt          DateTime?       // When ticket was resolved

  // Contact & Assignment
  contactId           String?
  contactName         String
  contactEmail        String
  assigneeId          String?

  // Timestamps
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  closedAt            DateTime?

  // Notifications
  slaNotifications    SLANotification[]
  activities          TicketActivity[]
  attachments         TicketAttachment[]
  nextSteps           TicketNextStep[]
  relatedTickets      RelatedTicket[]   @relation("TicketRelations")
  aiInsight           TicketAIInsight?

  @@index([ticketNumber])
  @@index([status])
  @@index([priority])
  @@index([slaStatus])
  @@index([assigneeId])
  @@index([contactId])
  @@index([tenantId])
  @@index([slaResolutionDue])
  // DBA-033: Missing slaPolicyId index for SLA policy lookups
  @@index([slaPolicyId])
  @@map("tickets")
}

model SLAPolicy {
  id                      String        @id @default(cuid())
  name                    String
  description             String?

  // Response time SLAs in minutes
  criticalResponseMinutes Int           @default(15)
  highResponseMinutes     Int           @default(60)
  mediumResponseMinutes   Int           @default(240)  // 4 hours
  lowResponseMinutes      Int           @default(480)  // 8 hours

  // Resolution time SLAs in minutes
  criticalResolutionMinutes Int         @default(120)  // 2 hours
  highResolutionMinutes     Int         @default(480)  // 8 hours
  mediumResolutionMinutes   Int         @default(1440) // 24 hours
  lowResolutionMinutes      Int         @default(4320) // 72 hours

  // Warning thresholds (percentage of time remaining)
  warningThresholdPercent Int           @default(25)   // Warn at 25% remaining

  isDefault               Boolean       @default(false)
  isActive                Boolean       @default(true)

  tenantId                String
  tenant                  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  tickets                 Ticket[]
  ticketAutomationSettings TicketAutomationSetting[]

  @@index([tenantId])
  // DBA-014: Tenant-scoped name uniqueness
  @@unique([tenantId, name])
  @@map("sla_policies")
}

model SLANotification {
  id              String                @id @default(cuid())
  ticketId        String
  ticket          Ticket                @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  type            SLANotificationType
  severity        SLANotificationSeverity @default(INFO)
  message         String
  sentAt          DateTime              @default(now())
  acknowledgedAt  DateTime?
  acknowledgedBy  String?

  // DBA-117: Multi-tenancy (DB has tenantId NOT NULL)
  tenantId        String
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([type])
  @@index([sentAt])
  @@index([tenantId])
  @@map("sla_notifications")
}

// ─── PG-185 Module Settings — Tickets ───────────────────────────────────────

model TicketDuplicateRule {
  id             String   @id @default(cuid())
  field          String   // "contact_subject" | "contact_24h" | "email_subject" | "contact_description_5min"
  matchStrategy  String   // "exact" | "normalized" | "fuzzy"
  threshold      Int      @default(100)
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, field, matchStrategy])
  @@index([tenantId])
  @@map("ticket_duplicate_rules")
}

model TicketRequiredField {
  id         String   @id @default(cuid())
  fieldKey   String   // "subject" | "description" | "contactEmail" | "contactName" | "priority" | "category" | "slaPolicy"
  isRequired Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, fieldKey])
  @@index([tenantId])
  @@map("ticket_required_fields")
}

model TicketTag {
  id          String   @id @default(cuid())
  name        String
  colorToken  String   @default("slate") // CHECK constraint: 18 allowed tokens (hardening migration)
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId, sortOrder])
  @@map("ticket_tags")
}

model TicketAutomationSetting {
  id                                  String   @id @default(cuid())
  // Default SLA selection (FK; ON DELETE SET NULL per hardening migration)
  defaultSlaPolicyId                  String?
  defaultSlaPolicy                    SLAPolicy? @relation(fields: [defaultSlaPolicyId], references: [id], onDelete: SetNull)
  // Auto-close rules (DoD explicit requirement)
  autoCloseIdleDays                   Int      @default(7)
  autoCloseAppliesToWaitingCustomer   Boolean  @default(true)
  autoCloseAppliesToResolved          Boolean  @default(true)
  autoCloseNotifyCustomer             Boolean  @default(true)
  // Duplicate-detection hygiene
  autoMergeOnExactContactSubject      Boolean  @default(false)
  notifyOnDuplicate                   Boolean  @default(true)
  // Tags & RBAC
  restrictTagCreationToAdmins         Boolean  @default(false)
  // Data hygiene
  normalizeSubjectCasing              Boolean  @default(true)
  trimDescriptionWhitespace           Boolean  @default(true)
  preventDeleteWithOpenChildren       Boolean  @default(true)
  // Notification triggers
  notifyOnAssigneeChange              Boolean  @default(true)
  notifyOnSlaBreach                   Boolean  @default(true)
  notifyOnSlaWarning                  Boolean  @default(false)
  notifyOnStatusResolved              Boolean  @default(false)
  notifyOnEscalation                  Boolean  @default(true)
  // AI & Intelligence — defaults FALSE (opt-in privacy; playbook §7)
  aiDuplicateDetection                Boolean  @default(false)
  aiAutoCategorization                Boolean  @default(false)
  aiSentimentAnalysis                 Boolean  @default(false)
  aiNextStepRecommendation            Boolean  @default(false)
  aiTagSuggestions                    Boolean  @default(false)
  aiInsightGeneration                 Boolean  @default(false)
  createdAt                           DateTime @default(now())
  updatedAt                           DateTime @updatedAt
  tenantId                            String   @unique
  tenant                              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([defaultSlaPolicyId])
  @@map("ticket_automation_settings")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING
  WAITING_ON_CUSTOMER
  WAITING_ON_THIRD_PARTY
  RESOLVED
  CLOSED
  ARCHIVED
}

enum TicketPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum SLAStatus {
  ON_TRACK       // Within SLA, plenty of time
  AT_RISK        // Getting close to breach (warning threshold)
  BREACHED       // SLA has been breached
  PAUSED         // SLA timer paused (waiting on customer)
  MET            // SLA was met (resolved in time)
}

enum SLANotificationType {
  WARNING          // Approaching SLA breach
  BREACH           // SLA has been breached
  ESCALATION       // Ticket has been escalated
  ASSIGNMENT       // Ticket has been assigned
  RESOLUTION       // Ticket has been resolved
}

enum SLANotificationSeverity {
  INFO
  WARNING
  CRITICAL
}

// ============================================
// TICKET ACTIVITIES (Timeline)
// ============================================

model TicketActivity {
  id              String                @id @default(cuid())
  type            TicketActivityType
  content         String
  timestamp       DateTime              @default(now())
  isInternal      Boolean               @default(false)

  // Author info
  authorName      String
  authorRole      String?               // 'Customer', 'Support Agent', 'System'
  authorAvatar    String?

  // Channel info
  channel         TicketChannel         @default(PORTAL)

  // AI-related
  isAIGenerated   Boolean               @default(false)
  aiConfidence    Float?

  // System event data
  systemEventType String?
  systemEventData Json?

  // Tenant isolation
  tenantId        String
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

