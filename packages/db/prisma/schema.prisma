model AuditLog {
  id            String    @id @default(cuid())
  action        String
  entityType    String
  entityId      String
  oldValue      Json?
  newValue      Json?
  // DBA-017: IP addresses capped at 45 chars for IPv6-mapped-IPv4
  ipAddress     String?   @db.VarChar(45)
  userAgent     String?
  createdAt     DateTime  @default(now())

  // Multi-tenancy
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
