  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, categoryKey])
  @@index([tenantId])
  @@map("document_retention_policies")
}

/// PG-126 — anonymous public-site feedback, captured BEFORE signup.
model PublicFeedback {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  email     String?
  source    String
  userAgent String?
  ipHash    String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([rating])
  @@map("public_feedback")
}
