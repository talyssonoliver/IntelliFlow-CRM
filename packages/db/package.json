{
  "name": "@intelliflow/db",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma database client for IntelliFlow CRM",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    },
    "./seed-ids": {
      "types": "./dist/seed-ids.d.ts",
      "import": "./dist/seed-ids.mjs",
      "require": "./dist/seed-ids.js"
    }
  },
  "scripts": {
    "build": "node -e \"try{require('fs').unlinkSync('generated/prisma/package.json')}catch(e){}\" && tsup && node scripts/postbuild-esm.mjs",
    "dev": "tsup --watch",
    "clean": "rm -rf dist .turbo",
    "db:generate": "prisma generate && node scripts/fix-prisma-esm.mjs",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:create": "prisma migrate dev --create-only",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx --env-file=.env prisma/seed.ts",
    "db:cleanup-legacy": "tsx --env-file=.env prisma/cleanup-legacy-seed-ids.ts",
    "db:cleanup-legacy:dry-run": "tsx --env-file=.env prisma/cleanup-legacy-seed-ids.ts --dry-run",
    "db:seed:help-articles": "pnpm run db:snapshot:help-articles:check && tsx --env-file=.env prisma/seed-help-articles.cli.ts",
    "db:snapshot:help-articles": "tsx prisma/scripts/generate-help-articles-snapshot.ts",
    "db:snapshot:help-articles:check": "tsx prisma/scripts/generate-help-articles-snapshot.ts --check",
    "typecheck:seed-help-articles": "tsc --noEmit --project prisma/tsconfig.seed.json",
    "db:reset": "prisma migrate reset --force",
    "typecheck": "node -e \"try{require('fs').unlinkSync('generated/prisma/package.json')}catch(e){}\" && tsc --noEmit && node scripts/fix-prisma-esm.mjs",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "tsx --env-file=.env prisma/seed.ts"
  },
  "dependencies": {
    "@intelliflow/domain": "workspace:*",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2"
  },
  "devDependencies": {
    "@intelliflow/typescript-config": "workspace:*",
    "@supabase/supabase-js": "^2.98.0",
    "@types/node": "^25.6.0",
    "prisma": "^7.7.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
