# Tooling scratch space
# Ignore .specify/ contents (not the directory itself) so carve-outs below work.
# Per git rules, negations can't re-include a child if the parent directory is ignored.
.specify/*
# Carve out: .specify/memory/** holds durable governance docs (Framework.md, constitution.md)
# referenced as FILE: prerequisites in Sprint_plan.csv (333 rows) and by
# tools/scripts/lib/stoa/paths.ts getConstitutionPath(). These MUST be tracked.
!.specify/memory/
!.specify/memory/**
# Carve out: .specify/sprints/** holds canonical task attestations used by CI validator
# and dashboard. This is the single source of truth for sprint task evidence.
!.specify/sprints/
!.specify/sprints/**
artifacts/misc/.locks/
apps/tree_intelliflow.txt

# Project tracker docs artifacts (runtime; keep folders, ignore contents)
apps/project-tracker/docs/artifacts/**
!apps/project-tracker/docs/artifacts/**/
!apps/project-tracker/docs/artifacts/**/.gitkeep

# Project tracker generated backups/artifacts
apps/project-tracker/docs/metrics/backups/
apps/project-tracker/docs/metrics/artifacts/
apps/project-tracker/docs/metrics/_global/*.tmp

# Sprint plan split files — tracked (agents use these for context; CI Metrics Tracked State gate requires no untracked files)
# apps/project-tracker/docs/metrics/_global/Sprint_plan_[A-Z].csv  # un-ignored: required by CI gate

# ============================================
# Project tracker runtime metric cache - Added 2026-04-10
# These JSON files contain only timestamp fields (verified_at, calculated_at,
# last_updated, notes: "Last synced") that are re-stamped on every server
# start. They are runtime cache, not source of truth.
# Source of truth: Sprint_plan.csv / Sprint_plan.json (tracked above).
# Schemas: apps/project-tracker/docs/metrics/schemas/ (tracked, see below).
# ============================================

# Per-sprint task JSON files are tracked — CI's validate:sprint (--strict) requires them
# to be git-tracked to pass Gate 3 (Evidence Integrity) and Gate 6 (Canonical Uniqueness).
# Only exclude phase-summary files (internal aggregates, timestamp-heavy) and _summary.json
# is excluded because .specify/sprints/sprint-N/_summary.json is the canonical copy.
apps/project-tracker/docs/metrics/sprint-*/_phase-summary.json
apps/project-tracker/docs/metrics/sprint-*/**/_phase-summary.json

# Global derived cache files - tracked (CI canonical uniqueness gate requires exactly 1 copy)
# task-registry.json and dependency-graph.json are now tracked (un-ignored)

# Runtime review queue (generated_at timestamp only)
apps/project-tracker/docs/metrics/review-queue.json

