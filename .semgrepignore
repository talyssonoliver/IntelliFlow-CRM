# Semgrep ignore rules for IntelliFlow CRM
#
# Pattern: tool/script files that use child_process / subprocess legitimately.
# These are dev-only automation scripts with no external-input attack surface.
# Production app code (apps/api, apps/web source) is NOT excluded.

# Developer tooling scripts — all use execSync/spawn with hardcoded or
# repo-internal inputs, never with untrusted user data.
tools/
scripts/
.agents/

# Project-tracker internal automation helpers
apps/project-tracker/app/api/audit/stream/route.ts
apps/project-tracker/lib/context-snapshot.ts
apps/project-tracker/lib/subprocess-spawner.ts

# Markdown renderer — dangerouslySetInnerHTML is safe here because parseMarkdown()
# escapes all HTML entities (&, <, >) before constructing the rendered string.
# No raw user input reaches the DOM without escaping.
apps/web/src/components/blog/markdown-renderer.tsx

# Test files — XSS strings inside test assertions are intentional inputs,
# not production render paths.
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
