<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_AutoResponse"
                  targetNamespace="http://intelliflow.com/autoresponse">

  <bpmn:process id="AutoResponseApprovalWorkflow" name="Auto-Response Approval Workflow" isExecutable="true">

    <!-- Start Event: Trigger Received -->
    <bpmn:startEvent id="StartEvent_TriggerReceived" name="Trigger Received">
      <bpmn:outgoing>Flow_ToGenerateResponse</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Task: Generate AI Response -->
    <bpmn:serviceTask id="Task_GenerateResponse" name="Generate AI Response">
      <bpmn:incoming>Flow_ToGenerateResponse</bpmn:incoming>
      <bpmn:outgoing>Flow_ToValidateLead</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Gateway: Validate Lead Status -->
    <bpmn:exclusiveGateway id="Gateway_ValidateLead" name="Lead Status Valid?">
      <bpmn:incoming>Flow_ToValidateLead</bpmn:incoming>
      <bpmn:outgoing>Flow_LeadValid</bpmn:outgoing>
      <bpmn:outgoing>Flow_LeadInvalid</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Task: Create Draft -->
    <bpmn:serviceTask id="Task_CreateDraft" name="Create Draft (DRAFT)">
      <bpmn:incoming>Flow_LeadValid</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSubmitApproval</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Task: Submit for Approval -->
    <bpmn:serviceTask id="Task_SubmitApproval" name="Submit for Approval (PENDING_APPROVAL)">
      <bpmn:incoming>Flow_ToSubmitApproval</bpmn:incoming>
      <bpmn:outgoing>Flow_ToHumanReview</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- User Task: Human Review -->
    <bpmn:userTask id="Task_HumanReview" name="Human Review Required">
      <bpmn:incoming>Flow_ToHumanReview</bpmn:incoming>
      <bpmn:incoming>Flow_EscalationResolved</bpmn:incoming>
      <bpmn:outgoing>Flow_ToApprovalDecision</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Gateway: Approval Decision -->
    <bpmn:exclusiveGateway id="Gateway_ApprovalDecision" name="Decision?">
      <bpmn:incoming>Flow_ToApprovalDecision</bpmn:incoming>
      <bpmn:outgoing>Flow_Approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_Rejected</bpmn:outgoing>
      <bpmn:outgoing>Flow_Escalate</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Task: Mark Approved -->
    <bpmn:serviceTask id="Task_Approved" name="Mark Approved (APPROVED)">
      <bpmn:incoming>Flow_Approved</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSendEmail</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Task: Send Email -->
    <bpmn:serviceTask id="Task_SendEmail" name="Send Email">
      <bpmn:incoming>Flow_ToSendEmail</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSendResult</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Gateway: Send Result -->
    <bpmn:exclusiveGateway id="Gateway_SendResult" name="Send Success?">
      <bpmn:incoming>Flow_ToSendResult</bpmn:incoming>
      <bpmn:outgoing>Flow_SendSuccess</bpmn:outgoing>
      <bpmn:outgoing>Flow_SendFailed</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Task: Mark Sent -->
    <bpmn:serviceTask id="Task_MarkSent" name="Mark Sent (SENT)">
      <bpmn:incoming>Flow_SendSuccess</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEndSuccess</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Task: Mark Failed -->
    <bpmn:serviceTask id="Task_MarkFailed" name="Mark Failed (FAILED)">
      <bpmn:incoming>Flow_SendFailed</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEndFailed</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Task: Mark Rejected -->
    <bpmn:serviceTask id="Task_Rejected" name="Mark Rejected (REJECTED)">
      <bpmn:incoming>Flow_Rejected</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEndRejected</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Task: Escalate -->
    <bpmn:serviceTask id="Task_Escalate" name="Escalate (ESCALATED)">
      <bpmn:incoming>Flow_Escalate</bpmn:incoming>
      <bpmn:outgoing>Flow_ToManagerReview</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- User Task: Manager Review -->
    <bpmn:userTask id="Task_ManagerReview" name="Manager Review">
      <bpmn:incoming>Flow_ToManagerReview</bpmn:incoming>
      <bpmn:outgoing>Flow_EscalationResolved</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Task: Mark Invalidated (Lead Invalid) -->
    <bpmn:serviceTask id="Task_Invalidated" name="Mark Invalidated (INVALIDATED)">
      <bpmn:incoming>Flow_LeadInvalid</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEndInvalidated</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- End Events -->
    <bpmn:endEvent id="EndEvent_Success" name="Response Sent">
      <bpmn:incoming>Flow_ToEndSuccess</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Failed" name="Send Failed">
      <bpmn:incoming>Flow_ToEndFailed</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Rejected" name="Response Rejected">
      <bpmn:incoming>Flow_ToEndRejected</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Invalidated" name="Response Invalidated">
      <bpmn:incoming>Flow_ToEndInvalidated</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="Flow_ToGenerateResponse" sourceRef="StartEvent_TriggerReceived" targetRef="Task_GenerateResponse" />
    <bpmn:sequenceFlow id="Flow_ToValidateLead" sourceRef="Task_GenerateResponse" targetRef="Gateway_ValidateLead" />
    <bpmn:sequenceFlow id="Flow_LeadValid" name="Valid" sourceRef="Gateway_ValidateLead" targetRef="Task_CreateDraft" />
    <bpmn:sequenceFlow id="Flow_LeadInvalid" name="Invalid" sourceRef="Gateway_ValidateLead" targetRef="Task_Invalidated" />
    <bpmn:sequenceFlow id="Flow_ToSubmitApproval" sourceRef="Task_CreateDraft" targetRef="Task_SubmitApproval" />
    <bpmn:sequenceFlow id="Flow_ToHumanReview" sourceRef="Task_SubmitApproval" targetRef="Task_HumanReview" />
    <bpmn:sequenceFlow id="Flow_ToApprovalDecision" sourceRef="Task_HumanReview" targetRef="Gateway_ApprovalDecision" />
    <bpmn:sequenceFlow id="Flow_Approved" name="Approve" sourceRef="Gateway_ApprovalDecision" targetRef="Task_Approved" />
    <bpmn:sequenceFlow id="Flow_Rejected" name="Reject" sourceRef="Gateway_ApprovalDecision" targetRef="Task_Rejected" />
    <bpmn:sequenceFlow id="Flow_Escalate" name="Escalate" sourceRef="Gateway_ApprovalDecision" targetRef="Task_Escalate" />
    <bpmn:sequenceFlow id="Flow_ToSendEmail" sourceRef="Task_Approved" targetRef="Task_SendEmail" />
    <bpmn:sequenceFlow id="Flow_ToSendResult" sourceRef="Task_SendEmail" targetRef="Gateway_SendResult" />
    <bpmn:sequenceFlow id="Flow_SendSuccess" name="Success" sourceRef="Gateway_SendResult" targetRef="Task_MarkSent" />
    <bpmn:sequenceFlow id="Flow_SendFailed" name="Failed" sourceRef="Gateway_SendResult" targetRef="Task_MarkFailed" />
    <bpmn:sequenceFlow id="Flow_ToEndSuccess" sourceRef="Task_MarkSent" targetRef="EndEvent_Success" />
    <bpmn:sequenceFlow id="Flow_ToEndFailed" sourceRef="Task_MarkFailed" targetRef="EndEvent_Failed" />
    <bpmn:sequenceFlow id="Flow_ToEndRejected" sourceRef="Task_Rejected" targetRef="EndEvent_Rejected" />
    <bpmn:sequenceFlow id="Flow_ToEndInvalidated" sourceRef="Task_Invalidated" targetRef="EndEvent_Invalidated" />
    <bpmn:sequenceFlow id="Flow_ToManagerReview" sourceRef="Task_Escalate" targetRef="Task_ManagerReview" />
    <bpmn:sequenceFlow id="Flow_EscalationResolved" sourceRef="Task_ManagerReview" targetRef="Task_HumanReview" />

  </bpmn:process>

  <!-- BPMN Diagram Layout -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_AutoResponse">
    <bpmndi:BPMNPlane id="BPMNPlane_AutoResponse" bpmnElement="AutoResponseApprovalWorkflow">
      <!-- Layout coordinates for visual representation -->
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
