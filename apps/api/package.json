{
  "name": "@intelliflow/api",
  "version": "0.1.0",
  "private": true,
  "description": "tRPC API server for IntelliFlow CRM",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "dotenv -e ../../.env.local -e ../../.env -- tsx watch src/main.ts",
    "dev:ws": "dotenv -e ../../.env.local -e ../../.env -- tsx watch src/ws-server.ts",
    "start:ws": "node dist/ws-server.js",
    "build": "tsup",
    "start": "node dist/main.js",
    "clean": "rm -rf dist .turbo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@intelliflow/adapters": "workspace:*",
    "@intelliflow/ai-worker": "workspace:*",
    "@intelliflow/application": "workspace:*",
    "@intelliflow/db": "workspace:*",
    "@intelliflow/domain": "workspace:*",
    "@intelliflow/observability": "workspace:*",
    "@intelliflow/platform": "workspace:*",
    "@intelliflow/validators": "workspace:*",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.77.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@opentelemetry/winston-transport": "^0.29.0",
    "@sentry/node": "^10.62.0",
    "@supabase/supabase-js": "^2.108.2",
    "@trpc/server": "^11.18.0",
    "bullmq": "^5.79.2",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@intelliflow/typescript-config": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@types/node": "^25.9.2",
    "@types/ws": "^8.5.10",
    "@vitest/ui": "^4.1.8",
    "eslint": "^10.4.1",
    "tsup": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.3.0",
    "vitest": "^4.1.8",
    "vitest-mock-extended": "^4.0.0"
  }
}
