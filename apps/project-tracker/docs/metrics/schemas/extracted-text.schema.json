{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "extracted-text.schema.json",
  "title": "Extracted Text Artifact Schema",
  "description": "Schema for OCR-extracted text artifacts stored for search and RAG",
  "type": "object",
  "properties": {
    "documentId": {
      "description": "Unique identifier of the source document",
      "type": "string",
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
    },
    "text": {
      "description": "Raw extracted text from OCR",
      "type": "string"
    },
    "normalizedText": {
      "description": "Normalized text with cleaned whitespace and characters",
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "sourceUrl": {
          "description": "Original document URL",
          "type": "string",
          "format": "uri"
        },
        "format": {
          "description": "Source document format",
          "type": "string",
          "enum": ["pdf", "png", "jpg", "jpeg", "tiff", "webp"]
        },
        "language": {
          "description": "ISO 639-1 language code",
          "type": "string",
          "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
        },
        "pageCount": {
          "description": "Number of pages processed",
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "wordCount": {
          "description": "Total word count in extracted text",
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "extractedAt": {
          "description": "ISO 8601 timestamp of extraction",
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
        },
        "engine": {
          "description": "OCR engine used for extraction",
          "type": "string",
          "enum": ["tesseract", "google-vision", "aws-textract", "azure-vision"]
        },
        "confidence": {
          "description": "Overall OCR confidence score (0-1)",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": [
        "sourceUrl",
        "format",
        "language",
        "pageCount",
        "wordCount",
        "extractedAt",
        "engine",
        "confidence"
      ],
      "additionalProperties": false
    },
    "searchableContent": {
      "description": "Text chunks optimized for search and RAG",
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "embeddings": {
      "description": "Vector embeddings for each searchable chunk",
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "number"
        }
      }
    },
    "provenance": {
      "type": "object",
      "properties": {
        "jobId": {
          "description": "OCR job identifier",
          "type": "string"
        },
        "processingTimeMs": {
          "description": "Processing time in milliseconds",
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "engineVersion": {
          "description": "OCR engine version used",
          "type": "string"
        },
        "retryCount": {
          "description": "Number of retries before success",
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "additionalProperties": false
    },
    "quality": {
      "type": "object",
      "properties": {
        "overallConfidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "characterAccuracy": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "pageConfidences": {
          "type": "array",
          "items": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "lowConfidenceRegions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "page": {
                "type": "integer",
                "minimum": -9007199254740991,
                "maximum": 9007199254740991
              },
              "x": {
                "type": "number"
              },
              "y": {
                "type": "number"
              },
              "width": {
                "type": "number"
              },
              "height": {
                "type": "number"
              },
              "confidence": {
                "type": "number"
              },
              "text": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "documentId",
    "text",
    "normalizedText",
    "metadata",
    "searchableContent"
  ],
  "additionalProperties": false
}
