{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "analytics-event.schema.json",
  "title": "Analytics Event Schema",
  "description": "Schema for IntelliFlow analytics events",
  "type": "object",
  "properties": {
    "eventId": {
      "description": "UUIDv4",
      "type": "string"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "eventName": {
      "type": "string"
    },
    "context": {
      "type": "object",
      "properties": {
        "environment": {
          "type": "string",
          "enum": ["development", "test", "staging", "production"]
        },
        "app": {
          "type": "string"
        },
        "sessionId": {
          "type": "string"
        },
        "subjectId": {
          "description": "Non-PII stable identifier (UUID). Do not use email/name.",
          "type": "string"
        }
      },
      "required": ["environment"],
      "additionalProperties": {}
    },
    "properties": {
      "description": "Event-specific fields (must not include PII)",
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    }
  },
  "required": ["eventId", "occurredAt", "eventName", "context"],
  "additionalProperties": false
}
