{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ci-failure-registry.schema.json",
  "title": "CI Failure Pattern Registry",
  "description": "Structured registry of recurring CI failure patterns at artifacts/reports/ci-failures/registry.json.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "first_seen": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "last_seen": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "occurrences": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991
          },
          "affected_workflows": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "guard_added": {
            "type": "boolean"
          },
          "guard_prs": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            }
          },
          "guard_pattern": {
            "type": "string",
            "minLength": 1
          },
          "verification_command": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "id",
          "title",
          "summary",
          "first_seen",
          "last_seen",
          "occurrences",
          "affected_workflows",
          "owner",
          "guard_added",
          "guard_prs",
          "guard_pattern",
          "verification_command",
          "evidence"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": ["schema_version", "generated_at", "owner", "patterns"],
  "additionalProperties": false
}
