{
  "name": "@intelliflow/worker-shared",
  "version": "0.0.1",
  "private": true,
  "description": "Shared worker infrastructure for IntelliFlow CRM",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm && tsc -p tsconfig.json --emitDeclarationOnly",
    "dev": "tsup src/index.ts --format cjs,esm --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "bullmq": "^5.78.1",
    "ioredis": "^5.11.1",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@intelliflow/typescript-config": "workspace:*",
    "@types/node": "^25.9.3",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@intelliflow/observability": "workspace:*",
    "@intelliflow/platform": "workspace:*"
  }
}
