{
  "name": "@intelliflow/workers",
  "version": "0.0.1",
  "private": true,
  "description": "IntelliFlow CRM Workers - Unified worker runtime",
  "scripts": {
    "build": "echo 'Workers meta-package - sub-workers built by root turbo'",
    "dev": "pnpm --filter @intelliflow/events-worker --filter @intelliflow/ingestion-worker --filter @intelliflow/notifications-worker run dev",
    "typecheck": "pnpm --filter @intelliflow/events-worker --filter @intelliflow/ingestion-worker --filter @intelliflow/notifications-worker run typecheck",
    "lint": "pnpm --filter @intelliflow/events-worker --filter @intelliflow/ingestion-worker --filter @intelliflow/notifications-worker run lint",
    "clean": "rimraf .turbo dist"
  },
  "devDependencies": {
    "@intelliflow/typescript-config": "workspace:*",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  }
}
