{
  "name": "@intelliflow/notifications-worker",
  "version": "0.0.1",
  "private": true,
  "description": "Multi-channel notification delivery worker",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "dotenv -e ../../../.env.local -e ../../../.env -- tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@intelliflow/adapters": "workspace:*",
    "@intelliflow/domain": "workspace:*",
    "@intelliflow/platform": "workspace:*",
    "@intelliflow/worker-shared": "workspace:*",
    "bullmq": "^5.77.3",
    "messagebird": "^4.0.1",
    "nodemailer": "^8.0.8",
    "pino": "^10.3.1",
    "twilio": "^5.12.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@intelliflow/typescript-config": "workspace:*",
    "@types/node": "^25.3.2",
    "@types/nodemailer": "^8.0.0",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.0.1",
    "@vitest/coverage-v8": "^4.0.16",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.16"
  }
}
