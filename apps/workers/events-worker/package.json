{
  "name": "@intelliflow/events-worker",
  "version": "0.0.1",
  "private": true,
  "description": "Transactional outbox poller for domain events",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "scripts": {
    "build": "tsup src/main.ts --format cjs,esm --dts",
    "dev": "dotenv -e ../../../.env.local -e ../../../.env -- tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@intelliflow/adapters": "workspace:*",
    "@intelliflow/db": "workspace:*",
    "@intelliflow/domain": "workspace:*",
    "@intelliflow/platform": "workspace:*",
    "@intelliflow/worker-shared": "workspace:*",
    "@prisma/adapter-pg": "^7.4.2",
    "bullmq": "^5.70.1",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@intelliflow/typescript-config": "workspace:*",
    "@types/node": "^25.3.2",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.16"
  }
}
