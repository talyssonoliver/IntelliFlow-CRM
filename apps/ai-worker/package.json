{
  "name": "@intelliflow/ai-worker",
  "version": "0.1.0",
  "private": true,
  "description": "AI Worker for IntelliFlow CRM - LangChain/CrewAI processing",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs,esm && tsc -p tsconfig.json --emitDeclarationOnly",
    "start": "node dist/index.js",
    "clean": "rm -rf dist .turbo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:chains": "vitest run --testPathPattern=chains",
    "ai:benchmark": "tsx src/scripts/benchmark.ts"
  },
  "dependencies": {
    "@intelliflow/db": "workspace:*",
    "@intelliflow/domain": "workspace:*",
    "@intelliflow/validators": "workspace:*",
    "@intelliflow/worker-shared": "workspace:*",
    "@langchain/core": "^1.1.29",
    "@langchain/ollama": "^1.2.5",
    "@langchain/openai": "^1.2.11",
    "bullmq": "^5.70.1",
    "dotenv": "^17.0.0",
    "js-tiktoken": "^1.0.15",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@intelliflow/typescript-config": "workspace:*",
    "@types/node": "^25.3.2",
    "eslint": "^10.0.2",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
