{
  "name": "@intelliflow/ai-worker",
  "version": "0.1.0",
  "private": true,
  "description": "AI Worker for IntelliFlow CRM - LangChain/CrewAI processing",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs,esm && tsc -p tsconfig.json --emitDeclarationOnly",
    "start": "node dist/index.js",
    "clean": "rm -rf dist .turbo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:chains": "vitest run --testPathPattern=chains",
    "ai:benchmark": "tsx src/scripts/benchmark.ts"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.3",
    "@bull-board/express": "^6.20.3",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.76.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@intelliflow/adapters": "workspace:*",
    "@intelliflow/application": "workspace:*",
    "@intelliflow/db": "workspace:*",
    "@intelliflow/domain": "workspace:*",
    "@intelliflow/observability": "workspace:*",
    "@intelliflow/platform": "workspace:*",
    "@intelliflow/validators": "workspace:*",
    "@intelliflow/worker-shared": "workspace:*",
    "@langchain/core": "^1.1.46",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.5",
    "bullmq": "^5.76.10",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "js-tiktoken": "^1.0.15",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@intelliflow/typescript-config": "workspace:*",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.2",
    "eslint": "^10.0.2",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
