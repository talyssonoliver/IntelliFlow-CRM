# ================================
# IntelliFlow AI Worker Configuration
# ================================

# ---------------------------------
# AI Provider Selection
# ---------------------------------
# Options: 'openai' (production) or 'ollama' (local development)
AI_PROVIDER=openai

# ---------------------------------
# OpenAI Configuration (Production)
# ---------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
# Optional OpenAI-compatible endpoint (e.g., vLLM on Linux/WSL)
# If set, a fallback local API key is used when OPENAI_API_KEY is empty.
# OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000
OPENAI_TIMEOUT=30000

# ---------------------------------
# Ollama Configuration (Local Dev)
# ---------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TEMPERATURE=0.7
OLLAMA_TIMEOUT=60000

# ---------------------------------
# Cost Tracking & Limits
# ---------------------------------
COST_TRACKING_ENABLED=true
# Warning threshold in USD
COST_WARNING_THRESHOLD=10.0
# Optional daily limit in USD (uncomment to enable)
# COST_DAILY_LIMIT=50.0

# ---------------------------------
# Performance Settings
# ---------------------------------
AI_CACHE_ENABLED=true
AI_CACHE_TTL=3600
AI_RATE_LIMIT=60
AI_RETRY_ATTEMPTS=3
AI_RETRY_DELAY=1000

# ---------------------------------
# Feature Flags
# ---------------------------------
ENABLE_CHAIN_LOGGING=true
ENABLE_CONFIDENCE_SCORES=true
ENABLE_STRUCTURED_OUTPUTS=true
ENABLE_MULTI_AGENT=false

# ---------------------------------
# Logging
# ---------------------------------
LOG_LEVEL=info
NODE_ENV=development

# ---------------------------------
# Worker Runtime
# ---------------------------------
HEALTH_PORT=5000
BULL_BOARD_PORT=3003

# ---------------------------------
# LiteLLM Proxy
# ---------------------------------
# Single OpenAI-compatible gateway for all AI chains in this worker.
# Start proxy: docker compose -f infra/docker/docker-compose.litellm.yml up -d
# Point OPENAI_BASE_URL at the proxy so all LangChain/CrewAI chains route through it.
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-litellm-dev-change-me
# Optional: PostgreSQL for budget tracking (matches root .env.example setting)
LITELLM_DATABASE_URL=

# Provider keys forwarded through the proxy
GROQ_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
# Note: OPENAI_API_KEY and OLLAMA_BASE_URL are already declared above.

# ---------------------------------------------------------------------------
# Direct providers (no LiteLLM proxy) — production default for IntelliFlow:
#   AI_PROVIDER=openrouter  → chat via OpenRouter free models (OpenAI-compatible)
#   EMBEDDING_PROVIDER=gemini → embeddings via Google gemini-embedding-001 @ 1536d
# Dev stays on AI_PROVIDER=ollama (local Docker). See ADR-048 / issue #238.
# ---------------------------------------------------------------------------
# OPENROUTER_API_KEY=sk-or-v1-...           # set above
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# Optional per-tier overrides (default to OPENROUTER_MODEL):
# OPENROUTER_MODEL_FREE=openai/gpt-oss-120b:free
# OPENROUTER_MODEL_STANDARD=openai/gpt-oss-120b:free
# OPENROUTER_MODEL_PREMIUM=openai/gpt-oss-120b:free
# OPENROUTER_SITE_URL=https://your-app-url   # OpenRouter attribution header

# Gemini embeddings (RAG / semantic search) — dim MUST match pgvector(1536):
EMBEDDING_PROVIDER=gemini
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=1536
