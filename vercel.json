{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "github": {
    "autoJobCancelation": true
  },
  "ignoreCommand": "git diff --quiet HEAD^ HEAD ':(exclude)*.md' ':(exclude)docs/**' ':(exclude).github/**'"
}
