# IntelliFlow CRM - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env files with actual secrets to version control

# ==============================================================================
# VAULT CONFIGURATION
# ==============================================================================
# HashiCorp Vault settings for secrets management
VAULT_ADDR=https://vault.intelliflow.local:8200
VAULT_NAMESPACE=intelliflow
VAULT_TOKEN=<your-vault-token>
VAULT_ROLE_ID=<your-role-id>
VAULT_SECRET_ID=<your-secret-id>

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
# Primary PostgreSQL database (managed via Supabase)
# Use pooled URL for runtime app traffic to prevent connection exhaustion.
DATABASE_URL=postgresql://user:password@db.your-project-ref.supabase.co:5432/postgres?pgbouncer=true&connection_limit=1
# Use direct URL only for Prisma migrations and admin scripts.
DIRECT_URL=postgresql://user:password@db.your-project-ref.supabase.co:5432/postgres
# Backward-compatible alias for older scripts
DATABASE_DIRECT_URL=postgresql://user:password@db.your-project-ref.supabase.co:5432/postgres
DATABASE_POOL_SIZE=20
DATABASE_SSL_MODE=require

# Supabase configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
SUPABASE_JWT_SECRET=<your-jwt-secret>
SUPABASE_PROJECT_REF=<your-project-ref>

# Supabase Auth - IFC-120 password reset & email verification
# For production: configure custom SMTP in Supabase dashboard to avoid spam folder (R-001)
APP_URL=http://localhost:3000

# Supabase Storage configuration
SUPABASE_STORAGE_URL=https://your-project.supabase.co/storage/v1
SUPABASE_MAX_FILE_SIZE=52428800

# Supabase Edge Functions (for local development)
SUPABASE_FUNCTIONS_URL=http://127.0.0.1:54321/functions/v1

# Redis configuration (for caching and rate limiting)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=<your-redis-password>
REDIS_TLS_ENABLED=false

# ==============================================================================
# AI / LLM CONFIGURATION
# ==============================================================================
# OpenAI API configuration
OPENAI_API_KEY=sk-...
# Optional OpenAI-compatible endpoint (vLLM, local gateway, etc.)
# OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_ORGANIZATION=<your-org-id>
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# Ollama configuration (for local development)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# LangChain configuration
LANGCHAIN_API_KEY=<your-langchain-key>
LANGCHAIN_PROJECT=intelliflow-crm
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ==============================================================================
# AUTHENTICATION & AUTHORIZATION
# ==============================================================================
# NextAuth.js configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=<generate-with-openssl-rand-base64-32>

# JWT configuration
JWT_SECRET=<your-jwt-secret>
JWT_EXPIRATION=7d
JWT_REFRESH_EXPIRATION=30d

# OAuth providers (optional)
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GITHUB_CLIENT_ID=<your-github-client-id>
GITHUB_CLIENT_SECRET=<your-github-client-secret>

# ==============================================================================
# API CONFIGURATION
# ==============================================================================
# tRPC API server
API_PORT=3001
API_HOST=0.0.0.0
API_CORS_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ==============================================================================
# FRONTEND CONFIGURATION
# ==============================================================================
# Next.js web application
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==============================================================================
# OBSERVABILITY & MONITORING
# ==============================================================================
# Sentry error tracking
SENTRY_DSN=<your-sentry-dsn>
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# OpenTelemetry configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=intelliflow-crm
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

# Grafana/Prometheus
PROMETHEUS_PORT=9090
GRAFANA_URL=http://localhost:3000

# PagerDuty integration
PAGERDUTY_API_KEY=<your-pagerduty-key>
PAGERDUTY_SERVICE_ID=<your-service-id>

# ==============================================================================
# DEPLOYMENT CONFIGURATION
# ==============================================================================
# Environment identifier
NODE_ENV=development
ENVIRONMENT=local

# Docker configuration
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_TAG=latest

# Railway (backend hosting) — used by Terraform provider, Railway CLI, and GH Actions
# Account-wide token (manage projects):    https://railway.app/account/tokens   -> RAILWAY_API_TOKEN
# Project-scoped token (deploy from CI):   Project Settings -> Tokens           -> RAILWAY_TOKEN
# Set BOTH to the same value if you only have an account token.
RAILWAY_API_TOKEN=<your-railway-account-token>
RAILWAY_TOKEN=<your-railway-project-or-account-token>
# Optional: pin deployments to a specific Railway project/environment instead of CLI prompts
RAILWAY_PROJECT_ID=
RAILWAY_ENVIRONMENT=production
# Mirror for Terraform — terraform reads TF_VAR_railway_token directly
TF_VAR_railway_token=<your-railway-account-or-project-token>

# Kubernetes (if applicable)
K8S_NAMESPACE=intelliflow
K8S_CLUSTER_NAME=production

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
# Enable/disable features for testing
FEATURE_AI_SCORING_ENABLED=true
FEATURE_EMAIL_AUTOMATION_ENABLED=false
FEATURE_ANALYTICS_ENABLED=true
FEATURE_EXPERIMENTAL_UI=false

# ==============================================================================
# EXTERNAL INTEGRATIONS
# ==============================================================================
# Email service (SendGrid, AWS SES, etc.)
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=<your-email-api-key>
EMAIL_FROM_ADDRESS=noreply@intelliflow.com
EMAIL_FROM_NAME=IntelliFlow CRM
# SEC-004: shared HMAC-SHA256 secret for the inbound-email webhook
# (apps/api/src/modules/email/inbound.router.ts `webhook`). Required — the
# webhook fails closed (401) when this is unset. Provider must sign the
# key-sorted JSON body and send the hex digest as `x-inbound-email-signature`.
INBOUND_EMAIL_WEBHOOK_SECRET=<generate-with-openssl-rand-hex-32>

# SMS service (Twilio)
TWILIO_ACCOUNT_SID=<your-twilio-account-sid>
TWILIO_AUTH_TOKEN=<your-twilio-auth-token>
TWILIO_PHONE_NUMBER=<your-twilio-phone>

# SMS Worker Configuration (IFC-222)
SMS_PROVIDER=mock                    # twilio | messagebird | mock
SMS_FROM=+15551234567                # Twilio sender phone number (replaces TWILIO_PHONE_NUMBER for worker)
ENABLE_SMS=false                     # Enable SMS delivery in notifications worker
SMS_STATUS_CALLBACK_URL=             # Twilio delivery status webhook URL (optional)

# File storage (AWS S3, GCS, etc.)
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=<your-aws-access-key>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-key>
AWS_REGION=us-east-1
AWS_S3_BUCKET=intelliflow-uploads

# ==============================================================================
# DEVELOPMENT TOOLS
# ==============================================================================
# Debug mode
DEBUG=false
LOG_LEVEL=info

# Testing
TEST_DATABASE_URL=postgresql://test:test@localhost:5433/intelliflow_test
TEST_REDIS_URL=redis://localhost:6380

# ==============================================================================
# SECURITY SETTINGS
# ==============================================================================
# Encryption keys
ENCRYPTION_KEY=<generate-with-openssl-rand-hex-32>
ENCRYPTION_ALGORITHM=aes-256-gcm

# prisma-field-encryption master key (AES-256-GCM, 32-byte random, base64-encoded).
# Encrypts ChainVersion.prompt, ChainVersion.systemPrompt, WebhookEndpoint.secret at rest.
# Generate a new key with:   openssl rand -base64 32
# For key rotation see:      docs/ops/runbooks/prompt-encryption-key-rotation.md
# Multi-key rotation syntax: PRISMA_FIELD_ENCRYPTION_KEY=new-key,old-key
# REQUIRED in production — server will refuse to start if missing or empty.
PRISMA_FIELD_ENCRYPTION_KEY=

# CORS configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Cookie settings
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=localhost

# ==============================================================================
# PERFORMANCE TUNING
# ==============================================================================
# Connection pooling
DATABASE_MIN_POOL_SIZE=2
DATABASE_MAX_POOL_SIZE=20
DATABASE_IDLE_TIMEOUT=30000

# Caching
CACHE_TTL=3600
CACHE_MAX_SIZE=100

# AI request timeouts
AI_REQUEST_TIMEOUT=30000
AI_MAX_RETRIES=3
AI_RETRY_DELAY=1000

# ==============================================================================
# CODE QUALITY & STATIC ANALYSIS
# ==============================================================================
# SonarQube (LOCAL Docker instance - NOT SonarCloud)
# Create token at: http://localhost:9000/account/security
# After starting: docker-compose -f docker-compose.sonarqube.yml up -d
SONAR_TOKEN=
SONAR_HOST_URL=http://localhost:9000

# Optional: SonarCloud (cloud service - different from local SonarQube)
# Only use if deploying to SonarCloud.io instead of local server
# SONARCLOUD_TOKEN=
# SONAR_ORGANIZATION=
# SONAR_PROJECT_KEY=intelliflow-crm

# ==============================================================================
# IMPORTANT NOTES FOR TOKEN CONFIGURATION
# ==============================================================================
# 1. This project uses LOCAL SonarQube Community (Docker)
# 2. DO NOT copy tokens from other projects (e-commerce-bags, etc.)
# 3. Create project-specific tokens for IntelliFlow CRM
# 4. SONAR_TOKEN is for local SonarQube (http://localhost:9000)
# 5. SONARCLOUD_TOKEN is for SonarCloud.io (cloud service)
# 6. See: docs/setup/sonarqube-token-guide.md for detailed setup
# ==============================================================================

# ==============================================================================
# LiteLLM Proxy
# ==============================================================================
# Single OpenAI-compatible gateway for all IntelliFlow AI chains.
# Start proxy: docker compose -f infra/docker/docker-compose.litellm.yml up -d
# Once running, chains should point OPENAI_BASE_URL at LITELLM_BASE_URL.
LITELLM_BASE_URL=http://localhost:4000
# Master key — any sk- prefixed string; used as Bearer token against the proxy.
LITELLM_MASTER_KEY=sk-litellm-dev-change-me
# Optional: PostgreSQL connection for virtual-key management & budget tracking.
# Leave blank to run the proxy without a database.
LITELLM_DATABASE_URL=

# Provider keys forwarded to the proxy (set the ones you use; leave others blank)
GROQ_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
# Note: OPENAI_API_KEY and OLLAMA_BASE_URL are already declared above.

# PG-126 — Public Feedback Widget
# Salt used to hash visitor IPs before persistence so raw IPs never reach
# the database or logs. MUST be unique per environment; production refuses
# to accept submissions when this is unset.
PUBLIC_FEEDBACK_IP_SALT="change-me-in-prod"

