# =============================================================================
# Terraform remote state — now HCP Terraform (see providers.tf `cloud {}`)
# =============================================================================
# The S3 backend was replaced by HCP Terraform (free tier): no AWS account, with
# built-in state locking + drift detection. The backend is configured by the
# `cloud {}` block in providers.tf — there is NO separate backend.tf to copy.
#
# One-time setup + the workspaces/token: docs/operations/runbooks/terraform-hcp-backend.md
#
# Required GitHub repo secret:
#   TF_API_TOKEN   (HCP Terraform API token)
#
# Local: `terraform login`, then `TF_WORKSPACE=intelliflow-crm-dev terraform init`.
#
# (The previous S3 example is kept below, commented, for reference only.)
# =============================================================================

# terraform {
#   backend "s3" {
#     bucket  = "intelliflow-terraform-state"
#     region  = "us-east-1"
#     encrypt = true
#     # dynamodb_table = "intelliflow-terraform-locks"
#   }
# }
