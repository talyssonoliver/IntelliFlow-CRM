# =============================================================================
# IntelliFlow CRM — Dev environment Terraform variables (TEMPLATE)
# =============================================================================
# Copy to terraform.tfvars in this directory and fill in real values.
# terraform.tfvars is gitignored by infra/terraform/.gitignore (*.tfvars).
#
# Apply from infra/terraform/:
#   source .env
#   terraform init -backend-config="key=crm/dev/terraform.tfstate"
#   terraform plan  -var-file=environments/dev/terraform.tfvars
#   terraform apply -var-file=environments/dev/terraform.tfvars
# =============================================================================

environment  = "dev"
project_name = "intelliflow-crm"
region       = "us-east-1"

tags = {
  Project    = "IntelliFlow-CRM"
  ManagedBy  = "Terraform"
  Repository = "intelliflow/intelliflow-crm"
  Team       = "Engineering"
  CostCenter = "Engineering"
  Env        = "dev"
}

# -----------------------------------------------------------------------------
# Supabase — values come from TF_VAR_supabase_access_token / TF_VAR_supabase_db_password
# (loaded by `source .env` from infra/terraform/.env). No need to hardcode here.
# -----------------------------------------------------------------------------
supabase_project_name = "intelliflow-crm-dev"
supabase_region       = "us-east-1"
supabase_plan         = "free"

# -----------------------------------------------------------------------------
# Vercel
# -----------------------------------------------------------------------------
vercel_project_name = "intelliflow-crm-dev"
vercel_framework    = "nextjs"
vercel_git_repo = {
  type = "github"
  repo = "talyssonoliver/intelliFlow-CRM"
}
vercel_domains = []

# -----------------------------------------------------------------------------
# Railway — services pull from GHCR images published by .github/workflows/build-images.yml
# -----------------------------------------------------------------------------
railway_project_name = "intelliflow-crm-dev"

railway_services = {
  api = {
    image    = "ghcr.io/talyssonoliver/intelliflow-crm-api:latest"
    replicas = 1
    memory   = "512Mi"
    cpu      = "0.5"
    env_vars = {
      PORT      = "4000"
      LOG_LEVEL = "debug"
    }
  }
  ai-worker = {
    image    = "ghcr.io/talyssonoliver/intelliflow-crm-ai-worker:latest"
    replicas = 1
    memory   = "1Gi"
    cpu      = "1"
    env_vars = {
      WORKER_CONCURRENCY = "3"
      LOG_LEVEL          = "debug"
    }
  }
}

# -----------------------------------------------------------------------------
# Extensions / auth / storage — keep defaults for dev
# -----------------------------------------------------------------------------
enable_pgvector = true
enable_realtime = true

auth_site_url   = "https://dev.intelliflow-crm.example"
auth_jwt_expiry = 3600

# Cost guardrails — keep low for dev
enable_cost_alerts   = true
cost_alert_threshold = 25
