# syntax=docker/dockerfile:1.7-labs
# IntelliFlow CRM - Web Application Dockerfile
# Multi-stage build for Next.js with optimal caching and security

# Stage 1: Dependencies
FROM node:20-alpine AS deps
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate

WORKDIR /app

# One COPY --parents per glob: empty glob fails with a clear error, not a hash miss
COPY --parents package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY --parents apps/*/package.json           ./
COPY --parents apps/workers/*/package.json   ./
COPY --parents packages/*/package.json       ./
COPY --parents tools/*/package.json          ./

# Install all dependencies (populates virtual store)
RUN pnpm install --frozen-lockfile --ignore-scripts

# Stage 2: Builder
FROM node:20-alpine AS builder
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate

WORKDIR /app

# Copy full virtual store from deps (all tarballs cached, no re-download)
COPY --from=deps /app/node_modules ./node_modules

# Copy full source tree (.dockerignore excludes node_modules, .next, dist, etc.)
COPY . .

# Re-link workspace symlinks against the copied virtual store
RUN pnpm install --frozen-lockfile --offline --ignore-scripts

# Set build-time environment variables
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ARG NEXT_OUTPUT=standalone
ENV NEXT_OUTPUT=${NEXT_OUTPUT}

# Increase Node.js heap for Next.js webpack build (default ~1.7 GB OOMs on large apps)
ENV NODE_OPTIONS=--max-old-space-size=4096
# Dummy build-time keys — satisfy production guards that fire during `next build`'s
# page-data collection phase (NODE_ENV=production). Real secrets are injected at runtime.
ARG PRISMA_FIELD_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
ENV PRISMA_FIELD_ENCRYPTION_KEY=${PRISMA_FIELD_ENCRYPTION_KEY}
ARG AI_AUDIT_SIGNING_KEY=build-time-placeholder-not-for-production
ENV AI_AUDIT_SIGNING_KEY=${AI_AUDIT_SIGNING_KEY}
# Supabase — getSupabaseConfig() in apps/api/src/lib/supabase.ts runs at module init
ARG SUPABASE_URL=https://supabase.example.com
ENV SUPABASE_URL=${SUPABASE_URL}
ARG SUPABASE_ANON_KEY=build-time-placeholder-not-for-production
ENV SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
ARG SUPABASE_SERVICE_ROLE_KEY=build-time-placeholder-not-for-production
ENV SUPABASE_SERVICE_ROLE_KEY=${SUPABASE_SERVICE_ROLE_KEY}

# Build workspace packages in dependency order (all use dist/ exports; CI has no pre-built dist/)
# Note: @intelliflow/ui exports from src/ directly — no build step needed
RUN pnpm --filter db db:generate
RUN pnpm --filter domain build
RUN pnpm --filter validators build
RUN pnpm --filter db build
RUN pnpm --filter application build
RUN pnpm --filter api-client build

# Build Next.js application
RUN pnpm --filter web build

# Stage 3: Runner
FROM node:20-alpine AS runner

# Set environment
ENV NODE_ENV=production
ENV PORT=3000
ENV NEXT_TELEMETRY_DISABLED=1

# Create non-root user
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

WORKDIR /app

# Copy necessary files from builder
COPY --from=builder /app/apps/web/public ./apps/web/public
COPY --from=builder /app/apps/web/package.json ./apps/web/package.json

# Automatically leverage output traces to reduce image size
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static

# Switch to non-root user
USER nextjs

# Expose port
EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD node -e "require('http').get('http://localhost:3000/api/health', (r) => {process.exit(r.statusCode === 200 ? 0 : 1)})"

# Start Next.js server
CMD ["node", "apps/web/server.js"]
