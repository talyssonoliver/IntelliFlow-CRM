# IntelliFlow CRM - Web Application Dockerfile
# Multi-stage build for Next.js with optimal caching and security

# Stage 1: Dependencies
FROM node:20-alpine AS deps
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate

WORKDIR /app

# Copy root manifests
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
# Copy each workspace package.json explicitly (glob flattens to one file — don't use)
COPY apps/ai-worker/package.json       ./apps/ai-worker/
COPY apps/api/package.json             ./apps/api/
COPY apps/project-tracker/package.json ./apps/project-tracker/
COPY apps/web/package.json             ./apps/web/
COPY apps/workers/package.json         ./apps/workers/
COPY packages/adapters/package.json        ./packages/adapters/
COPY packages/ai/package.json              ./packages/ai/
COPY packages/api-client/package.json      ./packages/api-client/
COPY packages/application/package.json    ./packages/application/
COPY packages/db/package.json              ./packages/db/
COPY packages/domain/package.json          ./packages/domain/
COPY packages/observability/package.json   ./packages/observability/
COPY packages/platform/package.json        ./packages/platform/
COPY packages/sdk/package.json             ./packages/sdk/
COPY packages/search/package.json          ./packages/search/
COPY packages/test-fixtures/package.json   ./packages/test-fixtures/
COPY packages/typescript-config/package.json ./packages/typescript-config/
COPY packages/ui/package.json              ./packages/ui/
COPY packages/validators/package.json      ./packages/validators/
COPY packages/webhooks/package.json        ./packages/webhooks/

# Install all dependencies (populates virtual store)
RUN pnpm install --frozen-lockfile --ignore-scripts

# Stage 2: Builder
FROM node:20-alpine AS builder
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate

WORKDIR /app

# Copy full virtual store from deps (all tarballs cached, no re-download)
COPY --from=deps /app/node_modules ./node_modules

# Copy full source tree (.dockerignore excludes node_modules, .next, dist, etc.)
COPY . .

# Re-link workspace symlinks against the copied virtual store
RUN pnpm install --frozen-lockfile --offline --ignore-scripts

# Set build-time environment variables
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

# Build shared packages first
RUN pnpm --filter ui build
RUN pnpm --filter api-client build

# Build Next.js application
RUN pnpm --filter web build

# Stage 3: Runner
FROM node:20-alpine AS runner

# Set environment
ENV NODE_ENV=production
ENV PORT=3000
ENV NEXT_TELEMETRY_DISABLED=1

# Create non-root user
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

WORKDIR /app

# Copy necessary files from builder
COPY --from=builder /app/apps/web/public ./apps/web/public
COPY --from=builder /app/apps/web/package.json ./apps/web/package.json

# Automatically leverage output traces to reduce image size
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static

# Switch to non-root user
USER nextjs

# Expose port
EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD node -e "require('http').get('http://localhost:3000/api/health', (r) => {process.exit(r.statusCode === 200 ? 0 : 1)})"

# Start Next.js server
CMD ["node", "apps/web/server.js"]
