# syntax=docker/dockerfile:1.7-labs
# IntelliFlow CRM - AI Worker Dockerfile
# Multi-stage build for LangChain/CrewAI worker service

# Stage 1: Dependencies
FROM node:20-alpine AS deps
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate

WORKDIR /app

# One COPY --parents per glob: empty glob fails with a clear error, not a hash miss
COPY --parents package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY --parents apps/*/package.json           ./
COPY --parents apps/workers/*/package.json   ./
COPY --parents packages/*/package.json       ./
COPY --parents tools/*/package.json          ./

# Install all dependencies (populates virtual store)
RUN pnpm install --frozen-lockfile --ignore-scripts

# Stage 2: Builder
FROM node:20-alpine AS builder
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate

# Install Python for AI dependencies
RUN apk add --no-cache python3 py3-pip build-base

WORKDIR /app

# Copy full virtual store + per-app/per-pkg symlink layer from deps stage.
# pnpm isolated linker creates both /app/node_modules AND
# /app/{apps,packages}/<name>/node_modules; missing the latter strands the
# per-app deps (dotenv, sdk-node, etc.) because pnpm install --frozen-lockfile
# below won't regenerate them when the lockfile already matches.
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps ./apps
COPY --from=deps /app/packages ./packages

# Copy full source tree (.dockerignore excludes node_modules; existing
# node_modules symlinks underneath are preserved).
COPY . .

# Re-link workspace symlinks against the copied virtual store.
RUN pnpm install --frozen-lockfile --offline --ignore-scripts

# Generate Prisma client
RUN pnpm --filter db db:generate

# Build workspace packages in dependency order before the worker compile.
# ai-worker imports @intelliflow/db, observability, worker-shared and adapters
# (all expose dist/ entrypoints), so they must be built first. Mirrors the
# proven build chain in Dockerfile.api.
RUN pnpm --filter domain build
RUN pnpm --filter validators build
RUN pnpm --filter webhooks build
RUN pnpm --filter platform build
RUN pnpm --filter db build
RUN pnpm --filter observability build
RUN pnpm --filter worker-shared build
RUN pnpm --filter application build
RUN pnpm --filter adapters build

# Build the AI worker
RUN pnpm --filter ai-worker build

# NOTE: `pnpm prune --prod` was removed intentionally — see Dockerfile.api.
# It strips per-app node_modules symlinks under pnpm isolated linker and
# crashes the runner with MODULE_NOT_FOUND for prod deps like dotenv.

# Stage 3: Runner
FROM node:20-alpine AS runner

# Install Python runtime for AI operations
RUN apk add --no-cache python3 py3-pip

# Set environment
ENV NODE_ENV=production
ENV PYTHONUNBUFFERED=1

# Create non-root user
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 aiworker

WORKDIR /app

# Copy necessary files from builder
# IMPORTANT: see Dockerfile.api — apps/ai-worker/node_modules is required for
# pnpm-symlinked dep resolution at runtime (OpenTelemetry, LangChain, etc.).
COPY --from=builder --chown=aiworker:nodejs /app/node_modules ./node_modules
COPY --from=builder --chown=aiworker:nodejs /app/packages ./packages
COPY --from=builder --chown=aiworker:nodejs /app/apps/ai-worker/dist ./apps/ai-worker/dist
COPY --from=builder --chown=aiworker:nodejs /app/apps/ai-worker/node_modules ./apps/ai-worker/node_modules
COPY --from=builder --chown=aiworker:nodejs /app/apps/ai-worker/package.json ./apps/ai-worker/
COPY --from=builder --chown=aiworker:nodejs /app/package.json ./

# Python dependencies: no requirements.txt is committed today (the
# worker is pure Node/@langchain/* per apps/ai-worker/package.json).
# Reintroduce the COPY + pip install lines if Python code lands later.

# Switch to non-root user
USER aiworker

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
  CMD node -e "require('http').get('http://localhost:5000/health', (r) => {process.exit(r.statusCode === 200 ? 0 : 1)})" || exit 1

# Start the AI worker
CMD ["node", "apps/ai-worker/dist/index.js"]
