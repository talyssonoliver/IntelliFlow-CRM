{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/git-destructive-guard.mjs",
            "timeout": 30,
            "statusMessage": "Checking git safety..."
          }
        ]
      }
    ]
  }
}
